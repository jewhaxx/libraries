        Tab.Active = Bool

        if Bool then
            TabButton.TextColor3 = Library.Theme.Text
            TabButton.TextTransparency = 0
            Library.ChangeItemTheme(TabButton, { TextColor3 = "Text" })

            TabAccent.Visible = true
            Library.Tween(TabAccent, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
