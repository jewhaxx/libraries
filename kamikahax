        if not Dropdown.IsOpen then
            Library.Tween(Selector, TweenInfo.new(0.12), { BackgroundColor3 = Library.Theme.Element })
        end
    end)

    local BuildItems = function()
        for _, Option in Dropdown.Options do
            Option.Button:Destroy()
        end
        Dropdown.Options = {}

        for Index, Item in Dropdown.Items do
            local OptionButton = InstanceNew("TextButton")
            OptionButton.Parent = List
            OptionButton.Name = "\0"
            OptionButton.BackgroundColor3 = Library.Theme.Element
            OptionButton.BorderColor3 = Library.Theme.Border
            OptionButton.BorderSizePixel = 1
            OptionButton.AutoButtonColor = false
            OptionButton.Size = UDim2New(1, 0, 0, 18)
            OptionButton.Font = Enum.Font.Code
            OptionButton.Text = Item
            OptionButton.TextColor3 = Library.Theme.TextDim
            OptionButton.TextSize = 12
            OptionButton.TextXAlignment = Enum.TextXAlignment.Left
            OptionButton.TextYAlignment = Enum.TextYAlignment.Center
            OptionButton.ZIndex = 6
            Library.AddToTheme(OptionButton, { BackgroundColor3 = "Element", BorderColor3 = "Border", TextColor3 = "TextDim" })

            local OptPad = InstanceNew("UIPadding")
            OptPad.Parent = OptionButton
            OptPad.PaddingLeft = UDimNew(0, 6)

            local OptStroke = InstanceNew("UIStroke")
            OptStroke.Parent = OptionButton
            OptStroke.Color = Library.Theme.Outline
            OptStroke.Thickness = 1
            OptStroke.LineJoinMode = Enum.LineJoinMode.Miter
            Library.AddToTheme(OptStroke, { Color = "Outline" })

            local IsSelected = false
            if Dropdown.Multi then
                IsSelected = Dropdown.Value and TableFind(Dropdown.Value, Item) ~= nil
            else
                IsSelected = Dropdown.Value == Item
            end

            if IsSelected then
                OptionButton.BackgroundColor3 = Library.Theme.Accent
                OptionButton.TextColor3 = FromRGB(15, 15, 18)
                Library.ChangeItemTheme(OptionButton, { BackgroundColor3 = "Accent", TextColor3 = "Text" })
            end

            Library.OnHover(OptionButton, function()
                if not (Dropdown.Multi and TableFind(Dropdown.Value or {}, Item)) and Dropdown.Value ~= Item then
                    Library.Tween(OptionButton, TweenInfo.new(0.1), { BackgroundColor3 = Library.Theme.HoveredElement })
                end
            end, function()
                if not (Dropdown.Multi and TableFind(Dropdown.Value or {}, Item)) and Dropdown.Value ~= Item then
                    Library.Tween(OptionButton, TweenInfo.new(0.1), { BackgroundColor3 = Library.Theme.Element })
                end
            end)

            Library.Connect(OptionButton.MouseButton1Down, function()
                if Dropdown.Multi then
                    Dropdown.Value = Dropdown.Value or {}
                    local FoundIndex = TableFind(Dropdown.Value, Item)
                    if FoundIndex then
                        TableRemove(Dropdown.Value, FoundIndex)
                        Library.Tween(OptionButton, TweenInfo.new(0.12), {
                            BackgroundColor3 = Library.Theme.Element,
                            TextColor3 = Library.Theme.TextDim
                        })
                        Library.ChangeItemTheme(OptionButton, { BackgroundColor3 = "Element", TextColor3 = "TextDim" })
                    else
                        TableInsert(Dropdown.Value, Item)
                        Library.Tween(OptionButton, TweenInfo.new(0.12), {
                            BackgroundColor3 = Library.Theme.Accent,
                            TextColor3 = FromRGB(15, 15, 18)
                        })
                        Library.ChangeItemTheme(OptionButton, { BackgroundColor3 = "Accent", TextColor3 = "Text" })
                    end

                    local DisplayText = #Dropdown.Value == 0 and "None" or table.concat(Dropdown.Value, ", ")
                    ValueLabel.Text = DisplayText
                else
                    Dropdown.Value = Item
                    ValueLabel.Text = Item

                    for _, Option in Dropdown.Options do
                        if Option.Button ~= OptionButton then
                            Library.Tween(Option.Button, TweenInfo.new(0.12), {
                                BackgroundColor3 = Library.Theme.Element,
                                TextColor3 = Library.Theme.TextDim
                            })
                            Library.ChangeItemTheme(Option.Button, { BackgroundColor3 = "Element", TextColor3 = "TextDim" })
                        end
                    end

                    Library.Tween(OptionButton, TweenInfo.new(0.12), {
                        BackgroundColor3 = Library.Theme.Accent,
                        TextColor3 = FromRGB(15, 15, 18)
                    })
                    Library.ChangeItemTheme(OptionButton, { BackgroundColor3 = "Accent", TextColor3 = "Text" })

                    Dropdown:SetOpen(false)
                end

                Library.Flags[Dropdown.Flag] = Dropdown.Value
                Library.SafeCall(Dropdown.Callback, Dropdown.Value)
            end)

            TableInsert(Dropdown.Options, { Button = OptionButton, Value = Item })
        end
