    Library.AddToTheme(Notification, { BackgroundColor3 = "Inline", BorderColor3 = "Border" })

    local AccentLine = InstanceNew("Frame")
    AccentLine.Parent = Notification
    AccentLine.Name = "\0"
    AccentLine.BackgroundColor3 = Color
    AccentLine.BorderColor3 = FromRGB(0, 0, 0)
    AccentLine.BorderSizePixel = 0
    AccentLine.Size = UDim2New(1, 0, 0, 2)

    local Padding = InstanceNew("UIPadding")
    Padding.Parent = Notification
    Padding.PaddingLeft = UDimNew(0, 10)
    Padding.PaddingRight = UDimNew(0, 10)
    Padding.PaddingTop = UDimNew(0, 8)
    Padding.PaddingBottom = UDimNew(0, 10)

    local Label = InstanceNew("TextLabel")
    Label.Parent = Notification
    Label.Name = "\0"
    Label.BackgroundTransparency = 1
    Label.BackgroundColor3 = FromRGB(255, 255, 255)
    Label.BorderColor3 = FromRGB(0, 0, 0)
    Label.BorderSizePixel = 0
    Label.Position = UDim2New(0, 0, 0, 4)
    Label.Size = UDim2New(1, 0, 0, 16)
    Label.Font = Enum.Font.Code
    Label.Text = Text
    Label.TextColor3 = Library.Theme.Text
    Label.TextSize = 13
    Label.TextWrapped = true
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.AutomaticSize = Enum.AutomaticSize.Y

    Library.AddToTheme(Label, { TextColor3 = "Text" })

    local Stroke = InstanceNew("UIStroke")
    Stroke.Parent = Notification
    Stroke.Color = Library.Theme.Outline
    Stroke.Thickness = 1
    Stroke.LineJoinMode = Enum.LineJoinMode.Miter

    Library.AddToTheme(Stroke, { Color = "Outline" })

    Notification.Size = UDim2New(1, 0, 0, 0)
    Library.Tween(Notification, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Size = UDim2New(1, 0, 0, 0)
    })

    task.delay(Duration, function()
        local Fade = Library.Tween(Notification, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            BackgroundTransparency = 1
        })

        Library.Tween(Label, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            TextTransparency = 1
        })

        Library.Tween(AccentLine, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            BackgroundTransparency = 1
        })

        Library.Tween(Stroke, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Transparency = 1
        })

        Fade.Completed:Wait()
        Notification:Destroy()
    end)

    return Notification
end

