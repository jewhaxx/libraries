Library.Sections.AddListbox = function(self, Data)
    Data = Data or {}

    local Listbox = {
        Window = self.Window,
        Tab = self.Tab,
        Section = self,
        Size = Data.Size or Data.size or 100,
        Items = Data.Items or Data.items or {},
        Default = Data.Default or Data.default or nil,
        Multi = Data.Multi or Data.multi or false,
        Flag = Data.Flag or Data.flag or Library.NextFlag(),
        Callback = Data.Callback or Data.callback or function() end,
        Value = nil,
        Options = {},
        Elements = {}
    }

    local Items = {}

    local Container = InstanceNew("Frame")
    Container.Parent = self.Elements.Content
    Container.Name = "\0"
    Container.BackgroundColor3 = Library.Theme.Inline
    Container.BorderColor3 = Library.Theme.Border
    Container.BorderSizePixel = 1
    Container.Size = UDim2New(1, 0, 0, Listbox.Size)
    Items.Container = Container

    local Stroke = InstanceNew("UIStroke")
    Stroke.Parent = Container
    Stroke.Color = Library.Theme.Outline
    Stroke.Thickness = 1
    Stroke.LineJoinMode = Enum.LineJoinMode.Miter
    Library.AddToTheme(Stroke, { Color = "Outline" })

    local Scroll = InstanceNew("ScrollingFrame")
    Scroll.Parent = Container
    Scroll.Name = "\0"
    Scroll.BackgroundTransparency = 1
    Scroll.BackgroundColor3 = FromRGB(255, 255, 255)
    Scroll.BorderColor3 = FromRGB(0, 0, 0)
    Scroll.BorderSizePixel = 0
    Scroll.Size = UDim2New(1, 0, 1, 0)
    Scroll.ScrollBarThickness = 3
    Scroll.ScrollBarImageColor3 = Library.Theme.Accent
    Scroll.ScrollBarImageTransparency = 0.5
    Scroll.CanvasSize = UDim2New(0, 0, 0, 0)
    Scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Library.AddToTheme(Scroll, { ScrollBarImageColor3 = "Accent" })

    local ScrollPad = InstanceNew("UIPadding")
    ScrollPad.Parent = Scroll
    ScrollPad.PaddingTop = UDimNew(0, 4)
    ScrollPad.PaddingBottom = UDimNew(0, 4)
    ScrollPad.PaddingLeft = UDimNew(0, 4)
    ScrollPad.PaddingRight = UDimNew(0, 4)

    local ScrollLayout = InstanceNew("UIListLayout")
    ScrollLayout.Parent = Scroll
    ScrollLayout.SortOrder = Enum.SortOrder.LayoutOrder
    ScrollLayout.Padding = UDimNew(0, 2)

    local BuildItems = function()
        for _, Option in Listbox.Options do
            Option:Destroy()
        end
        Listbox.Options = {}

        for Index, Item in Listbox.Items do
            local OptionButton = InstanceNew("TextButton")
            OptionButton.Parent = Scroll
            OptionButton.Name = "\0"
            OptionButton.BackgroundColor3 = Library.Theme.Element
            OptionButton.BorderColor3 = Library.Theme.Border
            OptionButton.BorderSizePixel = 1
            OptionButton.AutoButtonColor = false
            OptionButton.Size = UDim2New(1, 0, 0, 18)
            OptionButton.Font = Enum.Font.Code
            OptionButton.Text = Item
            OptionButton.TextColor3 = Library.Theme.TextDim
            OptionButton.TextSize = 12
            OptionButton.TextXAlignment = Enum.TextXAlignment.Left
            OptionButton.TextYAlignment = Enum.TextYAlignment.Center
            Library.AddToTheme(OptionButton, { BackgroundColor3 = "Element", BorderColor3 = "Border", TextColor3 = "TextDim" })

            local OptPad = InstanceNew("UIPadding")
            OptPad.Parent = OptionButton
            OptPad.PaddingLeft = UDimNew(0, 6)

            local OptStroke = InstanceNew("UIStroke")
            OptStroke.Parent = OptionButton
            OptStroke.Color = Library.Theme.Outline
            OptStroke.Thickness = 1
            OptStroke.LineJoinMode = Enum.LineJoinMode.Miter
            Library.AddToTheme(OptStroke, { Color = "Outline" })

            local IsSelected = false
            if Listbox.Multi then
                IsSelected = Listbox.Value and TableFind(Listbox.Value, Item) ~= nil
            else
                IsSelected = Listbox.Value == Item
            end

            if IsSelected then
                OptionButton.BackgroundColor3 = Library.Theme.Accent
                OptionButton.TextColor3 = FromRGB(15, 15, 18)
                Library.ChangeItemTheme(OptionButton, { BackgroundColor3 = "Accent", TextColor3 = "Text" })
            end

            Library.OnHover(OptionButton, function()
                if not (Listbox.Multi and TableFind(Listbox.Value or {}, Item)) and Listbox.Value ~= Item then
                    Library.Tween(OptionButton, TweenInfo.new(0.1), { BackgroundColor3 = Library.Theme.HoveredElement })
                end
            end, function()
                if not (Listbox.Multi and TableFind(Listbox.Value or {}, Item)) and Listbox.Value ~= Item then
                    Library.Tween(OptionButton, TweenInfo.new(0.1), { BackgroundColor3 = Library.Theme.Element })
                end
            end)

            Library.Connect(OptionButton.MouseButton1Down, function()
                if Listbox.Multi then
                    Listbox.Value = Listbox.Value or {}
                    local FoundIndex = TableFind(Listbox.Value, Item)
                    if FoundIndex then
                        TableRemove(Listbox.Value, FoundIndex)
                        Library.Tween(OptionButton, TweenInfo.new(0.12), {
                            BackgroundColor3 = Library.Theme.Element,
                            TextColor3 = Library.Theme.TextDim
                        })
                        Library.ChangeItemTheme(OptionButton, { BackgroundColor3 = "Element", TextColor3 = "TextDim" })
                    else
                        TableInsert(Listbox.Value, Item)
                        Library.Tween(OptionButton, TweenInfo.new(0.12), {
                            BackgroundColor3 = Library.Theme.Accent,
                            TextColor3 = FromRGB(15, 15, 18)
                        })
                        Library.ChangeItemTheme(OptionButton, { BackgroundColor3 = "Accent", TextColor3 = "Text" })
                    end
                else
                    Listbox.Value = Item

                    for _, Option in Listbox.Options do
                        if Option ~= OptionButton then
                            Library.Tween(Option, TweenInfo.new(0.12), {
                                BackgroundColor3 = Library.Theme.Element,
                                TextColor3 = Library.Theme.TextDim
                            })
                            Library.ChangeItemTheme(Option, { BackgroundColor3 = "Element", TextColor3 = "TextDim" })
                        end
                    end

                    Library.Tween(OptionButton, TweenInfo.new(0.12), {
                        BackgroundColor3 = Library.Theme.Accent,
                        TextColor3 = FromRGB(15, 15, 18)
                    })
                    Library.ChangeItemTheme(OptionButton, { BackgroundColor3 = "Accent", TextColor3 = "Text" })
                end

                Library.Flags[Listbox.Flag] = Listbox.Value
                Library.SafeCall(Listbox.Callback, Listbox.Value)
            end)

            TableInsert(Listbox.Options, OptionButton)
        end
    end

    Listbox.SetItems = function(self, NewItems)
        Listbox.Items = NewItems
        Listbox.Value = nil
        BuildItems()
    end

    Listbox.SetValue = function(self, Value)
        Listbox.Value = Value
        BuildItems()
        Library.Flags[Listbox.Flag] = Listbox.Value
    end

    Listbox.GetValue = function(self)
        return Listbox.Value
    end

    Listbox.SetVisible = function(self, Bool)
        Container.Visible = Bool
    end

    BuildItems()

    if Listbox.Default then
        Listbox:SetValue(Listbox.Default)
    end

    Library.SetFlags[Listbox.Flag] = function(Value)
        Listbox:SetValue(Value)
    end

    Listbox.Elements = Items
    return Listbox
end

