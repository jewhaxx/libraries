    local UpdateColor = function()
        Colorpicker.Color = FromHSV(Hue, Saturation, Value)
        Preview.BackgroundColor3 = Colorpicker.Color
        SVBox.BackgroundColor3 = FromHSV(Hue, 1, 1)
        SVCursor.Position = UDim2New(Saturation, 0, 1 - Value, 0)
        HueCursor.Position = UDim2New(Hue, 0, 0.5, 0)
        Library.Flags[Colorpicker.Flag] = Colorpicker.Color
        Library.SafeCall(Colorpicker.Callback, Colorpicker.Color)
    end

    local SVDragging = false
    local HueDragging = false

    local UpdateSV = function()
        local MousePos = UserInputService:GetMouseLocation()
        local RelX = MathClamp((MousePos.X - SVBox.AbsolutePosition.X) / SVBox.AbsoluteSize.X, 0, 1)
        local RelY = MathClamp((MousePos.Y - SVBox.AbsolutePosition.Y) / SVBox.AbsoluteSize.Y, 0, 1)
        Saturation = RelX
        Value = 1 - RelY
        UpdateColor()
    end

    local UpdateHue = function()
        local MousePos = UserInputService:GetMouseLocation()
        Hue = MathClamp((MousePos.X - HueBar.AbsolutePosition.X) / HueBar.AbsoluteSize.X, 0, 1)
        UpdateColor()
    end

    Library.Connect(SVBox.MouseButton1Down, function()
        SVDragging = true
        UpdateSV()
    end)

    Library.Connect(SVBox.InputEnded, function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            SVDragging = false
        end
    end)

    Library.Connect(HueBar.MouseButton1Down, function()
        HueDragging = true
        UpdateHue()
    end)

    Library.Connect(HueBar.InputEnded, function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            HueDragging = false
        end
    end)

    Library.Connect(UserInputService.InputChanged, function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseMovement then
            if SVDragging then
                UpdateSV()
            elseif HueDragging then
                UpdateHue()
            end
        end
    end)

    Colorpicker.Set = function(self, NewColor)
        Colorpicker.Color = NewColor
        local H, S, V = Color3.toHSV(NewColor)
        Hue, Saturation, Value = H, S, V
        UpdateColor()
    end

    Colorpicker.Get = function(self)
        return Colorpicker.Color
    end

    Colorpicker.SetOpen = function(self, Bool)
        Colorpicker.IsOpen = Bool
        Picker.Visible = Bool

        if Bool then
            local AbsPos = Button.AbsolutePosition
            local AbsSize = Button.AbsoluteSize
            Picker.Position = UDim2New(0, AbsPos.X, 0, AbsPos.Y + AbsSize.Y + 4)
        end
    end

    Library.Connect(Button.MouseButton1Down, function()
        Colorpicker:SetOpen(not Colorpicker.IsOpen)
    end)

    Library.Connect(UserInputService.InputBegan, function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 and Colorpicker.IsOpen then
            local MousePos = UserInputService:GetMouseLocation()
            local PickerPos = Picker.AbsolutePosition
            local PickerSize = Picker.AbsoluteSize
            local ButtonPos = Button.AbsolutePosition
            local ButtonSize = Button.AbsoluteSize

            local InPicker = MousePos.X >= PickerPos.X and MousePos.X <= PickerPos.X + PickerSize.X and MousePos.Y >= PickerPos.Y and MousePos.Y <= PickerPos.Y + PickerSize.Y
            local InButton = MousePos.X >= ButtonPos.X and MousePos.X <= ButtonPos.X + ButtonSize.X and MousePos.Y >= ButtonPos.Y and MousePos.Y <= ButtonPos.Y + ButtonSize.Y

            if not InPicker and not InButton then
                Colorpicker:SetOpen(false)
            end
        end
    end)

    local DefaultH, DefaultS, DefaultV = Color3.toHSV(Colorpicker.Color)
    Hue, Saturation, Value = DefaultH, DefaultS, DefaultV
    UpdateColor()

    Library.SetFlags[Colorpicker.Flag] = function(Value)
        Colorpicker:Set(Value)
    end

    Colorpicker.Elements = Items
    return Colorpicker
end

Library.CreateKeybind = function(self, Data)
