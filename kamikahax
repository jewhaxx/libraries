    Content.Parent = Inline
    Content.Name = "\0"
    Content.BackgroundTransparency = 1
    Content.BackgroundColor3 = FromRGB(255, 255, 255)
    Content.BorderColor3 = FromRGB(0, 0, 0)
    Content.BorderSizePixel = 0
    Content.Position = UDim2New(0, 0, 0, 27)
    Content.Size = UDim2New(1, 0, 1, -27)
    Items.Content = Content

    Library.MakeDraggable(MainFrame, TitleBar)
    Library.MakeResizeable(MainFrame, Vector2New(560, 360), Vector2New(1400, 1000))

    local FadeAll = function(Visibility)
        local Descendants = MainFrame:GetDescendants()
        TableInsert(Descendants, MainFrame)

        for _, Descendant in Descendants do
            local Properties = Library.GetTransparencyProperties(Descendant)
            if not Properties then continue end

            for _, Property in Properties do
                local OldTransparency = Descendant[Property]
                if Visibility then
                    Descendant[Property] = 1
                end

                local NewTween = Library.Tween(Descendant, TweenInfo.new(Window.FadeSpeed, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                    [Property] = Visibility and OldTransparency or 1
                })
            end
        end
    end

    Window.SetOpen = function(self, Bool)
        if Bool == Window.IsOpen then return end
        Window.IsOpen = Bool

        if Bool then
            MainFrame.Visible = true
            FadeAll(true)
        else
            FadeAll(false)
            task.delay(Window.FadeSpeed, function()
                if not Window.IsOpen then
                    MainFrame.Visible = false
                end
            end)
        end
    end

    Window.SetSize = function(self, NewSize)
        Window.Size = NewSize
        Library.Tween(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size = NewSize
        })
    end

    Window.SetTitle = function(self, NewTitle)
        Title.Text = NewTitle
        Window.Name = NewTitle
    end

    Window.Unload = function(self)
        Library:Unload()
    end

    Library.Connect(UserInputService.InputBegan, function(Input)
        if Input.KeyCode == Library.MenuKeybind then
            Window:SetOpen(not Window.IsOpen)
        end
    end)

    Window.Elements = Items
    return setmetatable(Window, Library)
end

