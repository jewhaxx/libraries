    ListPadding.PaddingLeft = UDimNew(0, 4)
    ListPadding.PaddingRight = UDimNew(0, 4)

    local ListLayout = InstanceNew("UIListLayout")
    ListLayout.Parent = List
    ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    ListLayout.Padding = UDimNew(0, 2)

    Library.OnHover(Selector, function()
