            })

            Page.Visible = true
            Library.Tween(Page, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
                BackgroundTransparency = 1
            })

            self.Window.ActivePage = self
        else
            TabButton.TextColor3 = Library.Theme.TextDim
            TabButton.TextTransparency = 0.35
            Library.ChangeItemTheme(TabButton, { TextColor3 = "TextDim" })

            Library.Tween(TabAccent, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
