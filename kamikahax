            Library.Tween(Selector, TweenInfo.new(0.12), { BackgroundColor3 = Library.Theme.Element })
        end
    end

    Dropdown.SetText = function(self, NewText)
        Label.Text = NewText
        Dropdown.Name = NewText
    end

    Dropdown.SetVisible = function(self, Bool)
        Container.Visible = Bool
    end

    Library.Connect(Selector.MouseButton1Down, function()
        Dropdown:SetOpen(not Dropdown.IsOpen)
    end)

    Library.Connect(UserInputService.InputBegan, function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 and Dropdown.IsOpen then
            local MousePos = UserInputService:GetMouseLocation()
            local ListPos = List.AbsolutePosition
            local ListSize = List.AbsoluteSize
            local SelectorPos = Selector.AbsolutePosition
            local SelectorSize = Selector.AbsoluteSize

            local InList = MousePos.X >= ListPos.X and MousePos.X <= ListPos.X + ListSize.X and MousePos.Y >= ListPos.Y and MousePos.Y <= ListPos.Y + ListSize.Y
            local InSelector = MousePos.X >= SelectorPos.X and MousePos.X <= SelectorPos.X + SelectorSize.X and MousePos.Y >= SelectorPos.Y and MousePos.Y <= SelectorPos.Y + SelectorSize.Y

            if not InList and not InSelector then
                Dropdown:SetOpen(false)
            end
        end
    end)

    BuildItems()

    if Dropdown.Default then
        Dropdown:SetValue(Dropdown.Default)
    end

    Library.SetFlags[Dropdown.Flag] = function(Value)
        Dropdown:SetValue(Value)
    end

    Dropdown.Elements = Items
    return Dropdown
end

