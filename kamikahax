    Button.TextColor3 = Library.Theme.Text
    Button.TextSize = 11
    Library.AddToTheme(Button, { BackgroundColor3 = "Element", BorderColor3 = "Border", TextColor3 = "Text" })
    Items.Button = Button

    local Stroke = InstanceNew("UIStroke")
    Stroke.Parent = Button
    Stroke.Color = Library.Theme.Outline
    Stroke.Thickness = 1
    Stroke.LineJoinMode = Enum.LineJoinMode.Miter
    Library.AddToTheme(Stroke, { Color = "Outline" })

    Library.OnHover(Button, function()
        Library.Tween(Button, TweenInfo.new(0.12), { BackgroundColor3 = Library.Theme.HoveredElement })
    end, function()
        Library.Tween(Button, TweenInfo.new(0.12), { BackgroundColor3 = Library.Theme.Element })
    end)

    Keybind.Set = function(self, NewKey)
        Keybind.Key = NewKey
        Button.Text = NewKey and tostring(NewKey):gsub("Enum.KeyCode.", "") or "None"
        Library.Flags[Keybind.Flag] = { Key = NewKey, Mode = Keybind.Mode }
        Library.SafeCall(Keybind.Callback, NewKey)
    end

    Keybind.Get = function(self)
        return Keybind.Key
    end

    Library.Connect(Button.MouseButton1Down, function()
        Keybind.Listening = true
        Button.Text = "..."
        Button.TextColor3 = Library.Theme.Accent
        Library.ChangeItemTheme(Button, { TextColor3 = "Accent" })
    end)

    Library.Connect(UserInputService.InputBegan, function(Input)
        if Keybind.Listening then
            if Input.KeyCode == Enum.KeyCode.Escape then
                Keybind.Listening = false
                Button.Text = Keybind.Key and tostring(Keybind.Key):gsub("Enum.KeyCode.", "") or "None"
                Button.TextColor3 = Library.Theme.Text
                Library.ChangeItemTheme(Button, { TextColor3 = "Text" })
                return
            end

            if Input.KeyCode ~= Enum.KeyCode.Unknown then
                Keybind:Set(Input.KeyCode)
                Keybind.Listening = false
                Button.TextColor3 = Library.Theme.Text
                Library.ChangeItemTheme(Button, { TextColor3 = "Text" })
            end
        elseif Keybind.Key and Input.KeyCode == Keybind.Key then
            if Keybind.Mode == "Toggle" then
                Library.SafeCall(Keybind.Callback, true)
                Library.Tween(Button, TweenInfo.new(0.1), { BackgroundColor3 = Library.Theme.Accent })
                task.delay(0.15, function()
                    Library.Tween(Button, TweenInfo.new(0.15), { BackgroundColor3 = Library.Theme.Element })
                end)
            else
                Library.SafeCall(Keybind.Callback, true)
                Library.Tween(Button, TweenInfo.new(0.1), { BackgroundColor3 = Library.Theme.Accent })
                task.delay(0.15, function()
                    Library.Tween(Button, TweenInfo.new(0.15), { BackgroundColor3 = Library.Theme.Element })
                    Library.SafeCall(Keybind.Callback, false)
                end)
            end
        end
    end)

    Library.SetFlags[Keybind.Flag] = function(Value)
        Keybind:Set(Value.Key or Value)
    end

    Keybind.Elements = Items
    return Keybind
end

Library.SetMenuKeybind = function(self, Keybind)
    self.MenuKeybind = Keybind
end

Library.Directory = "kimikahax"
Library.Folder = Library.Directory .. "/Configs"

if not isfolder(Library.Directory) then
    makefolder(Library.Directory)
end
if not isfolder(Library.Folder) then
    makefolder(Library.Folder)
end

Library.GetConfig = function(self)
    local Config = {}

    for FlagName, FlagValue in self.Flags do
        if type(FlagValue) == "table" and FlagValue.Key then
            Config[FlagName] = { Key = tostring(FlagValue.Key), Mode = FlagValue.Mode }
        elseif type(FlagValue) == "table" and FlagValue.Color then
            Config[FlagName] = { Color = "#" .. FlagValue.HexValue or "", Alpha = FlagValue.Alpha }
        elseif typeof(FlagValue) == "Color3" then
            local R, G, B = MathFloor(FlagValue.R * 255), MathFloor(FlagValue.G * 255), MathFloor(FlagValue.B * 255)
            Config[FlagName] = StringFormat("#%02X%02X%02X", R, G, B)
        else
            Config[FlagName] = FlagValue
        end
    end

    return HttpService:JSONEncode(Config)
end

Library.LoadConfig = function(self, ConfigString)
    local Success, Decoded = pcall(function()
        return HttpService:JSONDecode(ConfigString)
    end)

    if not Success then
        self:Notification("Invalid config file", 4, FromRGB(255, 70, 70))
        return
    end

    for FlagName, Value in Decoded do
        local SetFunction = self.SetFlags[FlagName]
        if SetFunction then
            if type(Value) == "table" and Value.Key then
                SetFunction(Value)
            elseif type(Value) == "string" and Value:sub(1, 1) == "#" then
                local Success2, Color = pcall(function()
                    return Color3.fromHex(Value:sub(2))
                end)
                if Success2 then
                    SetFunction(Color)
                end
            else
                SetFunction(Value)
            end
        end
    end

    self:Notification("Config loaded successfully", 4, Library.Theme.Accent)
end

Library.SaveConfig = function(self, Name)
    local FilePath = self.Folder .. "/" .. Name .. ".json"
    writefile(FilePath, self:GetConfig())
    self:Notification(StringFormat("Saved config: %s", Name), 4, Library.Theme.Accent)
end

Library.LoadConfigFile = function(self, Name)
    local FilePath = self.Folder .. "/" .. Name .. ".json"
    if not isfile(FilePath) then
        self:Notification(StringFormat("Config %s not found", Name), 4, FromRGB(255, 70, 70))
        return
    end

    local Content = readfile(FilePath)
    self:LoadConfig(Content)
end

Library.DeleteConfig = function(self, Name)
    local FilePath = self.Folder .. "/" .. Name .. ".json"
    if isfile(FilePath) then
        delfile(FilePath)
        self:Notification(StringFormat("Deleted config: %s", Name), 4, FromRGB(255, 70, 70))
    end
end

Library.ListConfigs = function(self)
    local Configs = {}
    local Success, Files = pcall(function()
        return listfiles(self.Folder)
    end)

    if not Success or not Files then
        return Configs
    end

    for _, File in Files do
        local FileName = File:match("([^/\\]+)%.json$")
        if FileName then
            TableInsert(Configs, FileName)
        end
    end

    return Configs
end

Library.CreateConfigUI = function(self, ParentSection)
    local CurrentConfig = nil

    local ConfigList = ParentSection:AddDropdown({
        Name = "Config",
        Items = self:ListConfigs(),
        Callback = function(Value)
            CurrentConfig = Value
        end
    })

    local RefreshButton = ParentSection:AddButton({
        Name = "Refresh Configs",
        Callback = function()
            ConfigList:SetItems(self:ListConfigs())
        end
    })

    local LoadButton = ParentSection:AddButton({
        Name = "Load Config",
        Callback = function()
            if CurrentConfig then
                self:LoadConfigFile(CurrentConfig)
            else
                self:Notification("No config selected", 3, FromRGB(255, 70, 70))
            end
        end
    })

    local SaveButton = ParentSection:AddButton({
        Name = "Save Config",
        Callback = function()
            if CurrentConfig then
                self:SaveConfig(CurrentConfig)
            else
                self:Notification("No config selected", 3, FromRGB(255, 70, 70))
            end
        end
    })

    local DeleteButton = ParentSection:AddButton({
        Name = "Delete Config",
        Callback = function()
            if CurrentConfig then
                self:DeleteConfig(CurrentConfig)
                ConfigList:SetItems(self:ListConfigs())
            end
        end
    })

    return ConfigList
end

return Library
