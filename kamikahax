local LibraryHelpers = {} do
    LibraryHelpers.Create = function(Class, Properties)
        local NewInstance = InstanceNew(Class)

        for Property, Value in Properties do
            NewInstance[Property] = Value
        end

        return NewInstance
    end

    LibraryHelpers.Round = function(Number, Float)
        local Multiplier = 1 / (Float or 1)
        return MathFloor(Number * Multiplier) / Multiplier
    end

    LibraryHelpers.AddToTheme = function(Instance, Properties)
        local ThemeData = {
            Instance = Instance,
            Properties = Properties
        }

        for Property, Value in Properties do
            if type(Value) == "string" then
                Instance[Property] = Library.Theme[Value]
            end
        end

        TableInsert(Library.ThemeItems, ThemeData)
        Library.ThemeMap[Instance] = ThemeData
    end

    LibraryHelpers.ChangeItemTheme = function(Instance, Properties)
        local ThemeData = Library.ThemeMap[Instance]
        if not ThemeData then
            return
        end

        for Property, Value in Properties do
            ThemeData.Properties[Property] = Value

            if type(Value) == "string" then
                Instance[Property] = Library.Theme[Value]
            else
                Instance[Property] = Value
            end
        end
    end

    LibraryHelpers.ApplyTheme = function(Theme)
        for Key, Value in Theme do
            Library.Theme[Key] = Value
        end

        for _, ThemeData in Library.ThemeItems do
            for Property, Value in ThemeData.Properties do
                if type(Value) == "string" then
                    ThemeData.Instance[Property] = Library.Theme[Value]
                end
            end
        end
    end

    LibraryHelpers.Connect = function(Event, Callback)
        local NewConnection = {
            Event = Event,
            Callback = Callback,
            Connection = nil
        }

        local Success = pcall(function()
            NewConnection.Connection = Event:Connect(Callback)
        end)

        TableInsert(Library.Connections, NewConnection)
        return NewConnection
    end

    LibraryHelpers.Thread = function(Function)
        local NewThread = coroutine.create(Function)
        task.defer(function()
            coroutine.resume(NewThread)
        end)
        TableInsert(Library.Threads, NewThread)
        return NewThread
    end

    LibraryHelpers.Tween = function(Instance, Info, Goal)
        Info = Info or Library.TweenInfo
        local NewTween = TweenService:Create(Instance, Info, Goal)
        NewTween:Play()
        return NewTween
    end

    LibraryHelpers.MakeDraggable = function(Instance, DragHandle)
        DragHandle = DragHandle or Instance

        local Dragging = false
        local DragStart = nil
        local StartPosition = nil

        Library.Connect(DragHandle.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Dragging = true
                DragStart = Input.Position
                StartPosition = Instance.Position

                Library.Connect(UserInputService.InputChanged, function(MoveInput)
                    if MoveInput.UserInputType == Enum.UserInputType.MouseMovement or MoveInput.UserInputType == Enum.UserInputType.Touch then
                        if Dragging then
                            local DragDelta = MoveInput.Position - DragStart
                            Instance.Position = UDim2New(
                                StartPosition.X.Scale, StartPosition.X.Offset + DragDelta.X,
                                StartPosition.Y.Scale, StartPosition.Y.Offset + DragDelta.Y
                            )
                        end
                    end
                end)
            end
        end)

        Library.Connect(DragHandle.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Dragging = false
            end
        end)
    end

    LibraryHelpers.MakeResizeable = function(Instance, Minimum, Maximum)
        local Resizing = false
        local StartSize = Instance.Size
        local StartInput = nil

        local ResizeHandle = InstanceNew("TextButton")
        ResizeHandle.Parent = Instance
        ResizeHandle.AnchorPoint = Vector2New(1, 1)
        ResizeHandle.BackgroundColor3 = FromRGB(255, 255, 255)
        ResizeHandle.BackgroundTransparency = 1
        ResizeHandle.AutoButtonColor = false
        ResizeHandle.BorderColor3 = FromRGB(0, 0, 0)
        ResizeHandle.BorderSizePixel = 0
        ResizeHandle.Name = "\0"
        ResizeHandle.Position = UDim2New(1, -2, 1, -2)
        ResizeHandle.Size = UDim2New(0, 14, 0, 14)
        ResizeHandle.Text = ""
        ResizeHandle.ZIndex = 10

        local ResizeLines = InstanceNew("ImageLabel")
        ResizeLines.Parent = ResizeHandle
        ResizeLines.AnchorPoint = Vector2New(1, 1)
        ResizeLines.BackgroundColor3 = FromRGB(255, 255, 255)
        ResizeLines.BackgroundTransparency = 1
        ResizeLines.BorderSizePixel = 0
        ResizeLines.Image = "rbxasset://textures/ui/GuiImagePlaceholder.png"
        ResizeLines.Size = UDim2New(0, 8, 0, 8)
        ResizeLines.Position = UDim2New(1, -2, 1, -2)
        ResizeLines.ImageColor3 = Library.Theme.TextDim
        ResizeLines.Visible = false

        Library.AddToTheme(ResizeLines, { ImageColor3 = "TextDim" })

        Library.Connect(ResizeHandle.MouseEnter, function()
            ResizeLines.Visible = true
        end)

        Library.Connect(ResizeHandle.MouseLeave, function()
            ResizeLines.Visible = false
        end)

        Library.Connect(ResizeHandle.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Resizing = true
                StartSize = Instance.Size
                StartInput = Input.Position
            end
        end)

        Library.Connect(ResizeHandle.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                Resizing = false
            end
        end)

        Library.Connect(UserInputService.InputChanged, function(Input)
            if Resizing and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
                local DragDelta = Input.Position - StartInput
                local NewSizeX = MathClamp(StartSize.X.Offset + DragDelta.X, Minimum.X, Maximum and Maximum.X or 99999)
                local NewSizeY = MathClamp(StartSize.Y.Offset + DragDelta.Y, Minimum.Y, Maximum and Maximum.Y or 99999)

                Library.Tween(Instance, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {
                    Size = UDim2New(0, NewSizeX, 0, NewSizeY)
                }):Wait()
            end
        end)
    end

    LibraryHelpers.OnHover = function(Instance, OnEnter, OnLeave)
        Library.Connect(Instance.MouseEnter, OnEnter)
        if OnLeave then
            Library.Connect(Instance.MouseLeave, OnLeave)
        end
    end

    LibraryHelpers.SafeCall = function(Function, ...)
        local Arguments = { ... }
        local Success, Result = pcall(Function, table.unpack(Arguments, 1, select("#", ...)))

        if not Success then
            warn(StringFormat("[Library] Error: %s", tostring(Result)))
            return false, Result
        end

        return true, Result
    end

    LibraryHelpers.GetTransparencyProperties = function(Item)
        if Item:IsA("Frame") then
            return { "BackgroundTransparency" }
        elseif Item:IsA("TextLabel") or Item:IsA("TextButton") then
            return { "BackgroundTransparency", "TextTransparency" }
        elseif Item:IsA("ImageLabel") or Item:IsA("ImageButton") then
            return { "BackgroundTransparency", "ImageTransparency" }
        elseif Item:IsA("ScrollingFrame") then
            return { "BackgroundTransparency", "ScrollBarImageTransparency" }
        elseif Item:IsA("TextBox") then
            return { "BackgroundTransparency", "TextTransparency" }
        elseif Item:IsA("UIStroke") then
            return { "Transparency" }
        end
    end

    LibraryHelpers.NextFlag = function()
        Library.UnnamedFlags += 1
        return StringFormat("Flag_%d_%s", Library.UnnamedFlags, HttpService:GenerateGUID(false))
    end
end

