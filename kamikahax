        Library.Flags[Slider.Flag] = Value

        local FormatString = Slider.Decimals == 0 and "%d%s" or "%." .. Slider.Decimals .. "f%s"
        ValueLabel.Text = StringFormat(FormatString, Value, Slider.Suffix)

        local Ratio = (Value - Slider.Min) / (Slider.Max - Slider.Min)
        Library.Tween(Fill, TweenInfo.new(0.12, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size = UDim2New(Ratio, 0, 1, 0)
        })

        Library.SafeCall(Slider.Callback, Value)
