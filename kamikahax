        Default = Data.Default or Data.default or nil,
        Mode = Data.Mode or Data.mode or "Toggle",
        Callback = Data.Callback or Data.callback or function() end,

        Key = Data.Default or Data.default or nil,
        Listening = false,
        Elements = {}
    }

    local Items = {}

    local Button = InstanceNew("TextButton")
    Button.Parent = Keybind.Parent
    Button.Name = "\0"
    Button.BackgroundColor3 = Library.Theme.Element
    Button.BorderColor3 = Library.Theme.Border
    Button.BorderSizePixel = 1
    Button.AutoButtonColor = false
    Button.Size = UDim2New(0, 50, 0, 14)
    Button.Font = Enum.Font.Code
