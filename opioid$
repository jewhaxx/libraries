            local VPSize = ViewportInstance.AbsoluteSize
            local box = GetBoundingBox2D(DummyModel, VpCamera, VPSize.X, VPSize.Y, true)
            if not box then
                DummyHolder.Visible = false
                return
            end

            local BoxW = box.MaxX - box.MinX
            local BoxH = box.MaxY - box.MinY
            DummyHolder.Position = UDim2New(0, box.MinX, 0, box.MinY)
            DummyHolder.Size = UDim2New(0, BoxW, 0, BoxH)
            DummyHolder.Visible = true

            local Status = PreviewStatus
            local Color = StatusColors[Status] or StatusColors.Neutral
            if ESPPreview.Config.UseStatusColors == false then
                Color = Library.Theme.Accent
            end

            if ESPPreview.Config.ShowName then
                local text = Status == "Local" and "LocalPlayer" or Status
                DummyNameLabel.Text = text
                DummyNameLabel.TextColor3 = Color
                DummyNameLabel.Visible = true
            else
                DummyNameLabel.Visible = false
            end

            if ESPPreview.Config.ShowBox then
