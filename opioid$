        while true do
            -- Optimization: skip the entire iteration when no rainbow colorpickers
            -- are registered. The original code iterated an empty table every 16ms.
            if #Library.RainbowColorpickers > 0 then
                Library.RainbowHue = (Library.RainbowHue + Library.RainbowSpeed) % 1

                local HasActive = false
                for _, Colorpicker in Library.RainbowColorpickers do
                    if Colorpicker.Rainbow and Colorpicker.Set then
                        HasActive = true
                        local Color = FromHSV(Library.RainbowHue, 1, 1)
                        pcall(function()
                            Colorpicker:Set(Color, Colorpicker.Alpha or 0)
                        end)
                    end
                end

                -- If no colorpicker is actually in rainbow mode, sleep longer
                -- (1s instead of 16ms) to reduce CPU usage.
                if HasActive then
                    task.wait(0.016)
                else
                    task.wait(1)
                end
            else
                task.wait(1)
            end
        end
    end)

