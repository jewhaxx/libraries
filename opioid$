        Instances.MakeDraggable = function(self)
            if not self.Instance then
                return
            end

            local Gui = self.Instance

            local Dragging = false
            local DragStart
            local StartPosition

            local Set = function(Input)
                local DragDelta = Input.Position - DragStart

                local NewX = StartPosition.X.Offset + DragDelta.X
                local NewY = StartPosition.Y.Offset + DragDelta.Y

                local ViewportX = Camera.ViewportSize.X
                local ViewportY = Camera.ViewportSize.Y
                local GuiWidth = Gui.AbsoluteSize.X
                local GuiHeight = Gui.AbsoluteSize.Y

                NewX = MathClamp(NewX, 0, ViewportX - GuiWidth)
                NewY = MathClamp(NewY, 0, ViewportY - GuiHeight)

                self:Tween(TweenInfo.new(0.16, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Position = UDim2New(0, NewX, 0, NewY)})
            end

            self:Connect("InputBegan", function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                    Dragging = true

                    DragStart = Input.Position
                    StartPosition = Gui.Position

                    if StartPosition.X.Scale ~= 0 or StartPosition.Y.Scale ~= 0 then
                        StartPosition = UDim2New(0, Gui.AbsolutePosition.X, 0, Gui.AbsolutePosition.Y)
                    end
                end
            end)

            self:Connect("InputEnded", function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
                    Dragging = false
                end
            end)

            Library:Connect(UserInputService.InputChanged, function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
                    if Dragging then
                        Set(Input)
                    end
                end
            end)

            return Dragging
        end

        Instances.MakeResizeable = function(self, Minimum, Maximum)
            if not self.Instance then 
                return
            end

            local Gui = self.Instance

            local Resizing = false 
            local Start = UDim2New()
            local Delta = UDim2New()
            local ResizeMax = Gui.Parent.AbsoluteSize - Gui.AbsoluteSize

            local ResizeButton = Instances:Create("TextButton", {
                                Parent = Gui,
                                AnchorPoint = Vector2New(1, 1),
                                BorderColor3 = FromRGB(0, 0, 0),
                                Size = UDim2New(0, 8, 0, 8),
