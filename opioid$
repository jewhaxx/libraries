                            end

                            local ParseLyrics = function(Body)
                                local Success, Data = pcall(function()
                                    return HttpService:JSONDecode(Body)
                                end)
                                if not Success or not Data then
                                    return nil
                                end

                                local Synced = nil
                                if type(Data) == "table" and Data.syncedLyrics then
                                    Synced = Data.syncedLyrics
                                elseif type(Data) == "table" and #Data > 0 then
                                    for _, Entry in Data do
                                        if Entry.syncedLyrics and Entry.syncedLyrics ~= "" then
                                            Synced = Entry.syncedLyrics
                                            break
                                        end
                                    end
                                end

                                if not Synced then
                                    return nil
                                end

                                local ParsedLines = {}
                                for Line in Synced:gmatch("[^\n]+") do
                                    local Min, Sec, Cs, Text = Line:match("%[(%d+):(%d+)%.(%d+)%](.*)")
                                    if Min then
                                        local CsNum = tonumber(Cs) or 0
                                        local CsLen = #Cs
                                        local MsMul = 10
                                        if CsLen == 1 then MsMul = 100
                                        elseif CsLen == 2 then MsMul = 10
                                        elseif CsLen >= 3 then MsMul = 1
                                        end
                                        local TimeMs = (tonumber(Min) * 60 + tonumber(Sec)) * 1000 + CsNum * MsMul
                                        TableInsert(ParsedLines, {
                                            time = TimeMs,
                                            text = Text or ""
                                        })
                                    end
                                end
                                if #ParsedLines > 0 then
                                    return ParsedLines
                                end
                                return nil
                            end

                            local DoRequest = function(Url)
                                local Success, Response = pcall(HttpRequest, {
                                    Url = Url,
                                    Method = "GET",
                                    Headers = {
                                        ["Accept"] = "application/json"
                                    },
                                    Timeout = 10
                                })
                                if not Success or not Response then
                                    return 0, ""
                                end
                                local Body = Response.Body or Response.body or ""
                                local Code = Response.StatusCode or Response.statusCode or Response.Status or 0
                                if type(Code) == "string" then
                                    Code = tonumber(Code:match("(%d+)")) or 0
                                end
                                return Code, Body
                            end

                            local Code, Body = DoRequest(
                                "https://lrclib.net/api/get?artist_name=" .. ArtistName .. "&album_name=" .. AlbumName .. "&track_name=" .. TrackName
                            )

                            local Parsed = nil
                            if Code == 200 and Body and Body ~= "" then
                                Parsed = ParseLyrics(Body)
                            end

                            if not Parsed then
                                Code, Body = DoRequest(
                                    "https://lrclib.net/api/search?track_name=" .. TrackName .. "&artist_name=" .. ArtistName
                                )
                                if Code == 200 and Body and Body ~= "" then
                                    Parsed = ParseLyrics(Body)
                                end
                            end

                            if not Parsed then
                                Code, Body = DoRequest(
                                    "https://lrclib.net/api/search?q=" .. TrackName
                                )
                                if Code == 200 and Body and Body ~= "" then
                                    Parsed = ParseLyrics(Body)
                                end
                            end

                            if Parsed then
                                State.Lyrics = Parsed
                            else
                                Items["LyricsCurrent"].Instance.Text = "No synced lyrics"
                            end
                        end)
                    end
                end
            end

            Items["PlayBtn"].Instance.Text = State.IsPlaying and "Pause" or "Play"
            Items["EqHolder"].Instance.Visible = State.IsPlaying

            if State.Duration > 0 then
                local Ratio = State.Progress / State.Duration
                Items["ProgressFill"].Instance.Size = UDim2New(Ratio, 0, 1, 0)
                Items["TimeLabel"].Instance.Text = FormatTime(State.Progress) .. " / " .. FormatTime(State.Duration)
            end

        end

        local UpdateLyrics = function()
            if State.Lyrics and #State.Lyrics > 0 then
                local CurrentLyricIdx = 0
                local AdjustedProgress = State.Progress
                for i, Line in State.Lyrics do
                    if Line.time <= AdjustedProgress then
                        CurrentLyricIdx = i
                    else
                        break
                    end
                end

                if CurrentLyricIdx ~= State.LastLyricIdx then
                    State.LastLyricIdx = CurrentLyricIdx

                    local PrevText = ""
                    local CurrText = ""
                    local NextText = ""

                    if CurrentLyricIdx > 0 then
                        PrevText = State.Lyrics[CurrentLyricIdx - 1] and State.Lyrics[CurrentLyricIdx - 1].text or ""
                        CurrText = State.Lyrics[CurrentLyricIdx].text or ""
                        NextText = State.Lyrics[CurrentLyricIdx + 1] and State.Lyrics[CurrentLyricIdx + 1].text or ""
                    else
                        CurrText = State.Lyrics[1] and State.Lyrics[1].text or ""
                        NextText = State.Lyrics[2] and State.Lyrics[2].text or ""
                    end

                    if CurrText == "" then
                        CurrText = "♪"
                    end

                    TweenService:Create(Items["LyricsCurrent"].Instance, TweenInfo.new(0.15), { TextTransparency = 1 }):Play()
                    task.delay(0.15, function()
                        Items["LyricsPrev"].Instance.Text = PrevText
