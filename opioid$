        local ButtonList = Data.Buttons or Data.buttons or {}
        local Count = math.min(#ButtonList, 3)  -- max 3 buttons

        if Count == 0 then
            return ButtonGroup
        end

        local Items = {} do
            -- Container frame — full width, auto-height. Holds the layout.
            Items["Container"] = Instances:Create("Frame", {
                Parent = ButtonGroup.Section.Elements["Content"].Instance,
                Name = "\0",
                BackgroundTransparency = 1,
                Size = UDim2New(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BorderSizePixel = 0,
                BackgroundColor3 = FromRGB(255, 255, 255),
            })

            -- Top row: holds Button1 + Button2 side by side (or just Button1 if Count == 1)
            local Row1, Row2
            if Count == 1 then
                -- Single button, full width, no row splitting
                Row1 = Items["Container"]
                Row2 = nil
            else
                Row1 = Instances:Create("Frame", {
                    Parent = Items["Container"].Instance,
                    Name = "\0",
                    BackgroundTransparency = 1,
                    Size = UDim2New(1, 0, 0, 17),
                    BorderSizePixel = 0,
                    BackgroundColor3 = FromRGB(255, 255, 255),
                })
                Instances:Create("UIListLayout", {
                    Parent = Row1.Instance,
                    FillDirection = Enum.FillDirection.Horizontal,
                    HorizontalFlex = Enum.UIFlexAlignment.Fill,
                    Padding = UDimNew(0, 4),
                    SortOrder = Enum.SortOrder.LayoutOrder,
                })
            end

            -- Row2 only exists when Count == 3 — Button3 full width below
            if Count == 3 then
                Row2 = Instances:Create("Frame", {
                    Parent = Items["Container"].Instance,
                    Name = "\0",
                    BackgroundTransparency = 1,
                    Size = UDim2New(1, 0, 0, 17),
                    Position = UDim2New(0, 0, 0, 21),
                    BorderSizePixel = 0,
                    BackgroundColor3 = FromRGB(255, 255, 255),
                })
            end

            -- Helper to build one button (same visual style as Section:Button)
            local function BuildButton(BtnData, Parent, Width)
                local Btn = {
                    Window = ButtonGroup.Window,
                    Page = ButtonGroup.Page,
                    Section = ButtonGroup.Section,
                    Name = BtnData.Name or BtnData.name or "Button",
                    Callback = BtnData.Callback or BtnData.callback or function() end,
                    Risky = BtnData.Risky or BtnData.risky or false,
                    RiskyText = BtnData.RiskyText or BtnData.riskytext or "Performing this action may have unintended consequences. Are you sure you want to continue?",
                    RiskConfirmed = false,
                    Flag = BtnData.Flag or BtnData.flag or Library:NextFlag(),
                }

                local BtnItems = {}
                BtnItems["Button"] = Instances:Create("TextButton", {
                    Parent = Parent,
                    BorderColor3 = FromRGB(10, 10, 10),
                    AutoButtonColor = false,
                    Name = "\0",
                    Size = Width or UDim2New(1, 0, 1, 0),
                    BorderSizePixel = 2,
                    BackgroundColor3 = FromRGB(33, 33, 36),
                })
                BtnItems["Button"]:AddToTheme({BackgroundColor3 = "Element", BorderColor3 = "Border"})

                Instances:Create("UIGradient", {
                    Parent = BtnItems["Button"].Instance,
                    Rotation = 90,
                    Color = RGBSequence{RGBSequenceKeypoint(0, FromRGB(255, 255, 255)), RGBSequenceKeypoint(1, FromRGB(100, 100, 100))}
                })

                Instances:Create("UIStroke", {
                    Parent = BtnItems["Button"].Instance,
                    ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
                    LineJoinMode = Enum.LineJoinMode.Miter,
                    Name = "\0",
                    Color = FromRGB(27, 27, 32)
                }):AddToTheme({Color = "Outline"})

                BtnItems["Text"] = Instances:Create("TextLabel", {
                    Parent = BtnItems["Button"].Instance,
                    FontFace = Library.Font,
                    TextColor3 = Btn.Risky and FromRGB(220, 90, 90) or FromRGB(215, 215, 215),
                    BorderColor3 = FromRGB(0, 0, 0),
                    Text = Btn.Risky and ("[!] " .. Btn.Name) or Btn.Name,
                    Name = "\0",
                    Size = UDim2New(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    TextTruncate = Enum.TextTruncate.AtEnd,
                    Position = UDim2New(0, 0, 0, -1),
                    BorderSizePixel = 0,
                    TextSize = 12,
                    BackgroundColor3 = FromRGB(255, 255, 255),
                })
                if Btn.Risky then
                    BtnItems["Text"]:AddToTheme({TextColor3 = "RiskyText"})
                else
                    BtnItems["Text"]:AddToTheme({TextColor3 = "Text"})
                end
                BtnItems["TextBorder"] = Instances:Create("UIStroke", {
                    Parent = BtnItems["Text"].Instance,
                    LineJoinMode = Enum.LineJoinMode.Miter,
                    Name = "\0"
                }):AddToTheme({Color = "Text Border"})

                BtnItems["Button"]:OnHover(function()
                    BtnItems["Button"]:Tween(nil, {BackgroundColor3 = Library.Theme["Hovered Element"]})
                    BtnItems["Button"]:ChangeItemTheme({BackgroundColor3 = "Hovered Element", BorderColor3 = "Border"})
                end)
                BtnItems["Button"]:OnHoverLeave(function()
                    BtnItems["Button"]:Tween(nil, {BackgroundColor3 = Library.Theme["Element"]})
                    BtnItems["Button"]:ChangeItemTheme({BackgroundColor3 = "Element", BorderColor3 = "Border"})
                end)

                function Btn:Press()
                    Library:SafeCall(Btn.Callback)
                    BtnItems["Text"]:ChangeItemTheme({TextColor3 = "Accent"})
                    BtnItems["Button"]:ChangeItemTheme({BackgroundColor3 = "Accent"})
                    BtnItems["Text"]:Tween(nil, {TextColor3 = Library.Theme.Accent})
                    BtnItems["Button"]:Tween(nil, {BackgroundColor3 = Library.Theme.Accent})
                    task.wait(0.1)
                    local RestoreTheme = Btn.Risky and "RiskyText" or "Text"
                    local RestoreColor = Btn.Risky and Library.Theme["RiskyText"] or Library.Theme.Text
                    BtnItems["Text"]:ChangeItemTheme({TextColor3 = RestoreTheme})
                    BtnItems["Button"]:ChangeItemTheme({BackgroundColor3 = "Element"})
                    BtnItems["Text"]:Tween(nil, {TextColor3 = RestoreColor})
                    BtnItems["Button"]:Tween(nil, {BackgroundColor3 = Library.Theme.Element})
                end

                function Btn:SetVisiblity(Bool)
                    BtnItems["Button"].Instance.Visible = Bool
                end

                BtnItems["Button"]:Connect("MouseButton1Down", function()
                    if Btn.Risky and not Btn.RiskConfirmed then
                        Library:RiskyPopup({
                            Window = Btn.Window,
                            Parent = Btn.Window.Elements["MainFrame"],
                            Text = Btn.RiskyText,
                            OnConfirm = function()
                                Btn.RiskConfirmed = true
                                Library.Flags[Btn.Flag] = true
                                Btn:Press()
                            end
                        })
                        return
                    end
                    Btn:Press()
                end)

                if BtnData.Tooltip or BtnData.tooltip then
                    Library:AddTooltip(BtnItems["Button"].Instance, BtnData.Tooltip or BtnData.tooltip)
                end

                Btn.Items = BtnItems
                return Btn
            end

            -- Layout:
            --   Count == 1: [    Button1    ] (full width)
            --   Count == 2: [ Button1 ][ Button2 ] (half width each)
            --   Count == 3: [ Button1 ][ Button2 ] (half width each)
            --               [    Button3          ] (full width)
            if Count == 1 then
                local b = BuildButton(ButtonList[1], Items["Container"].Instance, UDim2New(1, 0, 0, 17))
                TableInsert(ButtonGroup.Buttons, b)
            elseif Count == 2 then
                local b1 = BuildButton(ButtonList[1], Row1.Instance)
                local b2 = BuildButton(ButtonList[2], Row1.Instance)
                TableInsert(ButtonGroup.Buttons, b1)
                TableInsert(ButtonGroup.Buttons, b2)
            elseif Count == 3 then
                local b1 = BuildButton(ButtonList[1], Row1.Instance)
                local b2 = BuildButton(ButtonList[2], Row1.Instance)
                local b3 = BuildButton(ButtonList[3], Row2.Instance, UDim2New(1, 0, 1, 0))
                TableInsert(ButtonGroup.Buttons, b1)
                TableInsert(ButtonGroup.Buttons, b2)
                TableInsert(ButtonGroup.Buttons, b3)
            end
        end

        function ButtonGroup:SetVisibility(Bool)
            Items["Container"].Instance.Visible = Bool
        end

        return ButtonGroup
    end

