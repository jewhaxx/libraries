            Playerlist.Players[Name] = nil

            if Playerlist.CurrentPlayer and Playerlist.CurrentPlayer.Name == Name then
                Playerlist.CurrentPlayer = nil
                UpdateDetailPanel(nil)
            end
        end

        function Playerlist:Refresh()
            for _, Data in Playerlist.Players do
                if Data.AliveLabel then
                    Data.AliveLabel.Text = IsAlive(Data.Player) and "Yes" or "No"
                end
                if Data.DistanceLabel then
                    Data.DistanceLabel.Text = tostring(GetDistance(Data.Player)) .. "st"
                end
            end

            if Playerlist.CurrentPlayer then
                UpdateDetailPanel(Playerlist.CurrentPlayer)
            end
        end

        function Playerlist:GetSelected()
            return Playerlist.CurrentPlayer
        end

        function Playerlist:GetStatus(Player)
            if not Player then
                return nil
            end

            local Data = Playerlist.Players[Player.Name]
            return Data and Data.Status or "Neutral"
        end

        function Playerlist:GetAllStatuses()
            local Result = { }
            for Name, Data in Playerlist.Players do
                Result[Name] = Data.Status or "Neutral"
            end
            return Result
        end

        function Playerlist:SetStatus(Player, Status)
            if not Player then return end
            local Data = Playerlist.Players[Player.Name]
            if Data then
                Data.Status = Status
                Data.StatusLabel.Text = Status
                Data.StatusLabel.TextColor3 = StatusColors[Status] or StatusColors.Neutral
            end
        end

