        local MatchesSearch = function(Instance)
            local Query = InstanceTree.SearchQuery
            if not Query or Query == "" then
                return true
            end

            local Name, Class = FormatInstanceName(Instance)
            local LowerQuery = string.lower(Query)

            if string.find(string.lower(Name or ""), LowerQuery, 1, true) then
                return true
            end
            if string.find(string.lower(Class or ""), LowerQuery, 1, true) then
                return true
            end

            return false
        end

        local ShouldShowInSearch = function(Instance)
            if InstanceTree.SearchQuery == "" then
                return true
            end

            if MatchesSearch(Instance) then
                return true
            end

            local Success, Descendants = pcall(function()
                return Instance:GetDescendants()
            end)
            if Success and Descendants then
                for _, Descendant in Descendants do
                    if MatchesSearch(Descendant) then
                        return true
                    end
                end
            end

            return false
        end

        BuildRow = function(Instance, Depth)
            if not Instance then
                return
            end

            if InstanceTree.SearchQuery ~= "" and not ShouldShowInSearch(Instance) then
                return
            end

            local Name, Class = FormatInstanceName(Instance)

            local Children = { }
            local Success, Kids = pcall(function()
                return Instance:GetChildren()
            end)
            if Success and Kids then
                for _, Child in Kids do
                    TableInsert(Children, Child)
                end
            end

            local HasChildren = #Children > 0
            local Expanded = InstanceTree.SearchQuery ~= "" or InstanceTree.Expanded[Instance] == true

            local Entry = {
                Instance = Instance,
                Depth = Depth,
                Button = nil,
                Arrow = nil,
                Label = nil
            }

            Entry.Button = Instances:Create("TextButton", {
                Parent = Items["TreeScroll"].Instance,
                FontFace = Library.Font,
                TextColor3 = FromRGB(0, 0, 0),
                Text = "",
