            })

            Items["Confirm"] = Instances:Create("TextButton", {
                Parent = Items["ButtonHolder"].Instance,
                FontFace = Library.Font,
                Text = Popup.ConfirmText .. " (2.0s)",
                TextColor3 = FromRGB(140, 140, 150),
                BorderColor3 = FromRGB(10, 10, 10),
                BorderSizePixel = 2,
                AutoButtonColor = false,
