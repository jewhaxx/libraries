        local function Explorer_BuildEntries()
            Explorer_ClearEntries()

            local Success, Files = pcall(function()
                return listfiles(CurrentExplorerPath)
            end)

            if not Success or not Files then
                local Empty = Instances:Create("TextLabel", {
                    Parent = ExplorerScroll.Instance,
                    FontFace = Library.Font,
