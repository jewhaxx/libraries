                BackgroundTransparency = 1,
                BorderSizePixel = 0,
                TextSize = 11,
                TextXAlignment = Enum.TextXAlignment.Left,
                BackgroundColor3 = FromRGB(255, 255, 255),
                Name = "\0"
            })

            -- TextButton (not TextLabel) so the arrow actually captures clicks
            -- even with BackgroundTransparency = 1. TextLabel doesn't receive
            -- input events when its background is transparent, so the expand/collapse
            -- InputBegan handler below would never fire.
            Entry.Arrow = Instances:Create("TextButton", {
                Parent = Entry.Button.Instance,
                FontFace = Library.Font,
                TextColor3 = FromRGB(200, 200, 208),
                Text = HasChildren and (Expanded and "-" or "+") or "",
