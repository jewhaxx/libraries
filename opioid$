            Stroke.Parent = Frame.Instance

            Frame:AddToTheme({ BackgroundColor3 = "Element", BorderColor3 = "Border" })

            return Frame
        end

        local R6Layout = {
            Head = { Position = UDim2New(0.5, -11, 0, 3), Size = UDim2New(0, 22, 0, 28) },
            Torso = { Position = UDim2New(0.5, -22, 0, 34), Size = UDim2New(0, 45, 0, 45) },
            ["Left Arm"] = { Position = UDim2New(0.5, -43, 0, 34), Size = UDim2New(0, 17, 0, 45) },
            ["Right Arm"] = { Position = UDim2New(0.5, 27, 0, 34), Size = UDim2New(0, 17, 0, 45) },
            ["Left Leg"] = { Position = UDim2New(0.5, -22, 0, 81), Size = UDim2New(0, 20, 0, 50) },
            ["Right Leg"] = { Position = UDim2New(0.5, 3, 0, 81), Size = UDim2New(0, 20, 0, 50) },
            HumanoidRootPart = { Position = UDim2New(0.5, -11, 0, 45), Size = UDim2New(0, 22, 0, 22) }
        }

        local R15Layout = {
            Head = { Position = UDim2New(0.5, -11, 0, 3), Size = UDim2New(0, 22, 0, 28) },
            UpperTorso = { Position = UDim2New(0.5, -22, 0, 34), Size = UDim2New(0, 45, 0, 25) },
            LowerTorso = { Position = UDim2New(0.5, -22, 0, 62), Size = UDim2New(0, 45, 0, 17) },
            LeftUpperArm = { Position = UDim2New(0.5, -43, 0, 34), Size = UDim2New(0, 17, 0, 20) },
            LeftLowerArm = { Position = UDim2New(0.5, -43, 0, 56), Size = UDim2New(0, 17, 0, 14) },
            LeftHand = { Position = UDim2New(0.5, -43, 0, 71), Size = UDim2New(0, 17, 0, 7) },
            RightUpperArm = { Position = UDim2New(0.5, 27, 0, 34), Size = UDim2New(0, 17, 0, 20) },
            RightLowerArm = { Position = UDim2New(0.5, 27, 0, 56), Size = UDim2New(0, 17, 0, 14) },
            RightHand = { Position = UDim2New(0.5, 27, 0, 71), Size = UDim2New(0, 17, 0, 7) },
            LeftUpperLeg = { Position = UDim2New(0.5, -22, 0, 81), Size = UDim2New(0, 20, 0, 20) },
            LeftLowerLeg = { Position = UDim2New(0.5, -22, 0, 104), Size = UDim2New(0, 20, 0, 18) },
            LeftFoot = { Position = UDim2New(0.5, -22, 0, 125), Size = UDim2New(0, 20, 0, 7) },
            RightUpperLeg = { Position = UDim2New(0.5, 3, 0, 81), Size = UDim2New(0, 20, 0, 20) },
            RightLowerLeg = { Position = UDim2New(0.5, 3, 0, 104), Size = UDim2New(0, 20, 0, 18) },
            RightFoot = { Position = UDim2New(0.5, 3, 0, 125), Size = UDim2New(0, 20, 0, 7) },
            HumanoidRootPart = { Position = UDim2New(0.5, -11, 0, 45), Size = UDim2New(0, 22, 0, 22) }
        }

        local Layout = BodyPartBox.RigType == "R15" and R15Layout or R6Layout

        for _, PartName in Parts do
            local Props = Layout[PartName]
            if Props then
                local Frame = CreatePartFrame(PartName, Props)
                PartFrames[PartName] = Frame

                Frame:Connect("MouseButton1Down", function()
                    BodyPartBox:TogglePart(PartName)
                end)

                Frame:OnHover(function()
                    if not BodyPartBox.Selected[PartName] then
                        Frame:Tween(TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { BackgroundColor3 = Library.Theme["Hovered Element"] })
                    end
                end)

                Frame:OnHoverLeave(function()
                    if not BodyPartBox.Selected[PartName] then
                        Frame:Tween(TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { BackgroundColor3 = Library.Theme.Element })
                    end
                end)
                local PartTooltip = Data.Tooltips and (Data.Tooltips[PartName] or Data.Tooltips[PartName:lower()]) 
                    or Data.tooltips and (Data.tooltips[PartName] or Data.tooltips[PartName:lower()])
                    or Data.Tooltip or Data.tooltip
                if PartTooltip then
                    Library:AddTooltip(Frame.Instance, PartTooltip)
                end
            end
        end

        local UpdatePartVisual = function(PartName, Selected)
            local Frame = PartFrames[PartName]
            if not Frame then return end

            if Selected then
                Frame:Tween(TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { BackgroundColor3 = Library.Theme.Accent })
                Frame:ChangeItemTheme({ BackgroundColor3 = "Accent" })
            else
                Frame:Tween(TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), { BackgroundColor3 = Library.Theme.Element })
                Frame:ChangeItemTheme({ BackgroundColor3 = "Element" })
            end
        end

        function BodyPartBox:TogglePart(PartName)
            if self.Selected[PartName] then
                self.Selected[PartName] = nil
                UpdatePartVisual(PartName, false)
            else
                if not self.Multiple then
                    for OtherPart, _ in self.Selected do
                        self.Selected[OtherPart] = nil
                        UpdatePartVisual(OtherPart, false)
                    end
                end
                self.Selected[PartName] = true
                UpdatePartVisual(PartName, true)
            end

            local SelectedList = { }
            for Part, _ in self.Selected do
                TableInsert(SelectedList, Part)
            end

            Library.Flags[self.Flag] = SelectedList
            Library:SafeCall(self.Callback, SelectedList)
        end

        function BodyPartBox:Set(Parts)
            for Part, _ in self.Selected do
                self.Selected[Part] = nil
                UpdatePartVisual(Part, false)
            end

            self.Selected = { }

            if type(Parts) == "string" then
                Parts = { Parts }
            end

            if type(Parts) == "table" then
                for _, Part in Parts do
                    if PartFrames[Part] then
                        self.Selected[Part] = true
                        UpdatePartVisual(Part, true)
                    end
                end
            end

            local SelectedList = { }
            for Part, _ in self.Selected do
                TableInsert(SelectedList, Part)
            end

            Library.Flags[self.Flag] = SelectedList
            Library:SafeCall(self.Callback, SelectedList)
        end

        function BodyPartBox:Get()
            local SelectedList = { }
            for Part, _ in self.Selected do
                TableInsert(SelectedList, Part)
            end
            return SelectedList
        end

        function BodyPartBox:SetVisibility(Bool)
            Items["Holder"].Instance.Visible = Bool
        end

        function BodyPartBox:Clear()
            for Part, _ in self.Selected do
                self.Selected[Part] = nil
                UpdatePartVisual(Part, false)
            end
            self.Selected = { }
            Library.Flags[self.Flag] = { }
            Library:SafeCall(self.Callback, { })
        end

        for _, Part in BodyPartBox.Default do
            if PartFrames[Part] then
                BodyPartBox.Selected[Part] = true
                UpdatePartVisual(Part, true)
            end
        end

        local SelectedList = { }
        for Part, _ in BodyPartBox.Selected do
            TableInsert(SelectedList, Part)
        end
        Library.Flags[BodyPartBox.Flag] = SelectedList

        Library.SetFlags[BodyPartBox.Flag] = function(Value)
            BodyPartBox:Set(Value)
        end

        BodyPartBox.Items = Items
        BodyPartBox.PartFrames = PartFrames

        return BodyPartBox
    end

end

getgenv().Library = Library
return Library
