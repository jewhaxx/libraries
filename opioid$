        local ProjectPointViewport = function(worldPos, cam, vpWidth, vpHeight)
            local rel = cam.CFrame:PointToObjectSpace(worldPos)
            if rel.Z >= -0.1 then
                return nil, false
            end

            local halfFovRad = math.rad(cam.FieldOfView) / 2
            local tanHalfFov = math.tan(halfFovRad)
            local aspect = vpWidth / vpHeight

            local ndcX = (rel.X / -rel.Z) / (tanHalfFov * aspect)
            local ndcY = (rel.Y / -rel.Z) / tanHalfFov

            local screenX = (ndcX + 1) * 0.5 * vpWidth
            local screenY = (1 - ndcY) * 0.5 * vpHeight

            return Vector2New(screenX, screenY), true
        end

        local ProjectPointScreen = function(worldPos, cam)
            local screenPos, onScreen = cam:WorldToViewportPoint(worldPos)
            if not onScreen then
