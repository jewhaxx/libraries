        local function DrawPlayerESP(player)
            if not ESPPreview.Config.Enabled then
                ClearPlayerOverlay(player)
                return
            end

            local Char = player.Character
            if not Char then
                ClearPlayerOverlay(player)
                return
            end

            local Hum = Char:FindFirstChildOfClass("Humanoid")
            if not Hum then
                ClearPlayerOverlay(player)
                return
            end

            local overlay = EnsurePlayerOverlay(player)

            local box = GetBoundingBox2D(Char, Camera, 0, 0, false)
            if not box then
                overlay.Holder.Visible = false
                return
            end

            local BoxW = box.MaxX - box.MinX
            local BoxH = box.MaxY - box.MinY
            overlay.Holder.Position = UDim2New(0, box.MinX, 0, box.MinY)
            overlay.Holder.Size = UDim2New(0, BoxW, 0, BoxH)
            overlay.Holder.Visible = true

            local Status = "Neutral"
            if player == LocalPlayer then
                Status = "Local"
            elseif Library.PlayerlistInstance then
                local S = Library.PlayerlistInstance:GetStatus(player)
                if S and S ~= "" then
                    Status = S
                end
            end

            local Color = StatusColors[Status] or StatusColors.Neutral
            if ESPPreview.Config.UseStatusColors == false then
                Color = Library.Theme.Accent
            end

            if ESPPreview.Config.ShowBox then
                overlay.BoxHandler.Visible = true
                overlay.BoxOutline.Visible = true
                overlay.BoxStroke.Color = Color
                overlay.BoxStroke.Thickness = 1
            else
                overlay.BoxHandler.Visible = false
                overlay.BoxOutline.Visible = false
            end

            if ESPPreview.Config.ShowName then
                overlay.NameLabel.Text = player.DisplayName
                overlay.NameLabel.TextColor3 = Color
                overlay.NameLabel.Visible = true
            else
                overlay.NameLabel.Visible = false
            end

            if ESPPreview.Config.ShowHealth then
