        local CurrentContextMenuItems = { }

        local RebuildContextMenu = function(Instance)
            for _, Item in CurrentContextMenuItems do
                if Item and Item.Instance then
                    Item:Clean()
                end
            end
            CurrentContextMenuItems = { }

            if not Instance then
                return
            end

            local Name, Class = FormatInstanceName(Instance)
            local Path = GetInstancePath(Instance)

            TableInsert(CurrentContextMenuItems, AddContextMenuItem("Copy Path", function()
                if setclipboard then
                    setclipboard(Path)
                    Library:Notification("Path copied: " .. Path, 2, Library.Theme.Accent)
                end
            end))

            TableInsert(CurrentContextMenuItems, AddContextMenuItem("Copy Name", function()
                if setclipboard then
