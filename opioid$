                    if overlay.BoxOutline then overlay.BoxOutline:Destroy() end
                    if overlay.NameLabel then overlay.NameLabel:Destroy() end
                    if overlay.HpBg then overlay.HpBg:Destroy() end
                    if overlay.HpFill then overlay.HpFill:Destroy() end
                    if overlay.Holder then overlay.Holder:Destroy() end
                end)
            end
            PlayerOverlays[player] = nil
        end

