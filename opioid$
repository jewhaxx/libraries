                if setclipboard then
                    setclipboard(Class)
                    Library:Notification("ClassName copied: " .. Class, 2, Library.Theme.Accent)
                end
            end))

            local ItemHeight = 20
            local VerticalPadding = 4
            local TotalHeight = ItemHeight * #CurrentContextMenuItems + VerticalPadding
            Items["ContextMenu"].Instance.Size = UDim2New(0, 140, 0, TotalHeight)
        end


        OpenContextMenu = function(Instance)
            RebuildContextMenu(Instance)

            if not Instance then
                return
            end

            local MousePos = UserInputService:GetMouseLocation()
            local GuiInset = game:GetService("GuiService"):GetGuiInset().Y
            local ScreenPos = Vector2New(MousePos.X, MousePos.Y - GuiInset)

            local WindowPos = Items["Window"].Instance.AbsolutePosition
            local RelativeX = ScreenPos.X - WindowPos.X
            local RelativeY = ScreenPos.Y - WindowPos.Y

            local MenuWidth = 140
            local MenuHeight = Items["ContextMenu"].Instance.AbsoluteSize.Y
            if MenuHeight == 0 then
                MenuHeight = 64
            end
            local WindowWidth = Items["Window"].Instance.AbsoluteSize.X
            local WindowHeight = Items["Window"].Instance.AbsoluteSize.Y

            if RelativeX + MenuWidth > WindowWidth then
                RelativeX = WindowWidth - MenuWidth
            end
            if RelativeY + MenuHeight > WindowHeight then
                RelativeY = WindowHeight - MenuHeight
            end
            if RelativeX < 0 then RelativeX = 0 end
            if RelativeY < 0 then RelativeY = 0 end

            Items["ContextMenu"].Instance.Position = UDim2New(0, RelativeX, 0, RelativeY)
            Items["ContextMenu"].Instance.Visible = true
            ContextMenu.Visible = true
            JustOpenedMenu = true
            task.delay(0.15, function()
                JustOpenedMenu = false
            end)
        end

        Library:Connect(UserInputService.InputBegan, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 and ContextMenu.Visible then
                if not JustOpenedMenu and not Library:IsMouseOverFrame(Items["ContextMenu"]) then
                    CloseContextMenu()
                end
                JustOpenedMenu = false
            end
            if Input.UserInputType == Enum.UserInputType.MouseButton2 and ContextMenu.Visible then
                if not JustOpenedMenu and not Library:IsMouseOverFrame(Items["ContextMenu"]) then
                    CloseContextMenu()
                end
                JustOpenedMenu = false
            end
        end)

        function InstanceTree:Refresh()
            self.Roots = CollectRoots()

            if self.Selected and (not self.Selected.Parent and self.Selected ~= game) then
                self.Selected = nil
                BuildPropsFor(nil)
            else
                BuildPropsFor(self.Selected)
            end

            RebuildTree()
        end

        function InstanceTree:SetVisibility(Bool)
            if Items["Window"] and Items["Window"].Instance then
                Items["Window"].Instance.Visible = Bool
                if not Bool then
                    CloseContextMenu()
                end
            end
        end

        function InstanceTree:Select(Instance)
            self.Selected = Instance
            BuildPropsFor(Instance)
            RebuildTree()
        end

        function InstanceTree:ToggleExpand(Instance)
            if not Instance then
                return
            end
            self.Expanded[Instance] = not (self.Expanded[Instance] == true)
            RebuildTree()
        end

        function InstanceTree:SetSearch(Query)
            self.SearchQuery = (Query or ""):gsub("^%s+", ""):gsub("%s+$", "")
            RebuildTree()
        end

        Items["Refresh"]:Connect("MouseButton1Down", function()
            InstanceTree:Refresh()
            Library:Notification("Instance tree refreshed", 2, Library.Theme.Accent)
        end)

        Items["Close"]:Connect("MouseButton1Down", function()
            if InstanceTree.CloseToggle and InstanceTree.CloseToggle.Set then
                InstanceTree.CloseToggle:Set(false)
            else
                InstanceTree:SetVisibility(false)
            end
        end)

        Items["SearchBox"]:Connect("FocusLost", function()
            InstanceTree:SetSearch(Items["SearchBox"].Instance.Text)
        end)

        Items["SearchBox"].Instance:GetPropertyChangedSignal("Text"):Connect(function()
            InstanceTree:SetSearch(Items["SearchBox"].Instance.Text)
        end)

        InstanceTree.Roots = CollectRoots()
        InstanceTree:Refresh()

        InstanceTree.Items = Items
        Library.InstanceTreeInstance = InstanceTree

        return InstanceTree
    end

