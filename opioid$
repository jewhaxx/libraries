        task.spawn(function()
            while true do
                if State.IsPlaying and Items["EqHolder"].Instance.Visible then
                    local Now = os.clock()
                    local dt = State.LastFrameTime > 0 and (Now - State.LastFrameTime) or 0.033
                    State.LastFrameTime = Now
                    dt = MathClamp(dt, 0.016, 0.1)

                    State.Progress = State.Progress + (dt * 1000)
                    local ProgressSec = State.Progress / 1000

                    local CurrentSegment = nil
                    if State.Segments and #State.Segments > 0 then
                        while State.LastSegIdx <= #State.Segments do
                            local Seg = State.Segments[State.LastSegIdx]
                            if Seg.start and Seg.start <= ProgressSec then
                                CurrentSegment = Seg
                                State.LastSegIdx = State.LastSegIdx + 1
                            else
                                break
                            end
                        end
                        if not CurrentSegment and State.LastSegIdx > 1 then
                            CurrentSegment = State.Segments[State.LastSegIdx - 1]
                        end
                    end

                    if State.Beats and #State.Beats > 0 then
                        while State.LastBeatIdx <= #State.Beats do
                            local Beat = State.Beats[State.LastBeatIdx]
                            if Beat.start and Beat.start <= ProgressSec then
                                State.BeatPulse = 1
                                State.LastBeatIdx = State.LastBeatIdx + 1
                            else
                                break
                            end
                        end
                    else
                        local BeatInterval = 60 / State.Tempo
                        local BeatPhase = ProgressSec % BeatInterval
                        if BeatPhase < dt * 2 then
                            State.BeatPulse = 1
                        end
                    end

                    State.BeatPulse = State.BeatPulse * (1 - dt * 6)
                    if State.BeatPulse < 0.01 then
                        State.BeatPulse = 0
                    end

                    local BeatSpeed = (State.Tempo / 60) * 2 * math.pi * dt
                    State.BassPhase = State.BassPhase + BeatSpeed
                    State.MidPhase = State.MidPhase + BeatSpeed * 2.1
                    State.TreblePhase = State.TreblePhase + BeatSpeed * 3.7

                    local Pitches = nil
                    local Loudness = -15

                    if CurrentSegment then
                        Pitches = CurrentSegment.pitches
                        Loudness = CurrentSegment.loudness_max or CurrentSegment.loudness_start or -15
                    end

                    local LoudnessNorm = MathClamp((Loudness + 30) / 30, 0.3, 1.5)
                    local BeatBoost = State.BeatPulse * 7
                    local EnergyMul = 0.4 + State.Energy * 0.6
                    local DanceMul = 0.4 + State.Danceability * 0.6

                    for i, Bar in EqBars do
                        local PitchVal = 0
                        if Pitches and #Pitches >= 12 then
                            if i == 1 then
                                PitchVal = ((Pitches[1] or 0) + (Pitches[2] or 0)) * 0.5
                            elseif i == 2 then
                                PitchVal = ((Pitches[3] or 0) + (Pitches[4] or 0)) * 0.5
                            elseif i == 3 then
                                PitchVal = ((Pitches[5] or 0) + (Pitches[6] or 0)) * 0.5
                            elseif i == 4 then
                                PitchVal = ((Pitches[7] or 0) + (Pitches[8] or 0)) * 0.5
                            elseif i == 5 then
                                PitchVal = ((Pitches[9] or 0) + (Pitches[10] or 0)) * 0.5
                            elseif i == 6 then
                                PitchVal = ((Pitches[11] or 0) + (Pitches[12] or 0)) * 0.5
                            end
                        end

                        local SynthBase
                        local SynthAmp
                        local Phase

                        if i <= 2 then
                            Phase = State.BassPhase + i * 0.5
                            SynthBase = 2
                            SynthAmp = 8 * EnergyMul
                        elseif i <= 4 then
                            Phase = State.MidPhase + i * 0.3
                            SynthBase = 2
                            SynthAmp = 6 * DanceMul
                        else
                            Phase = State.TreblePhase + i * 0.2
                            SynthBase = 2
                            SynthAmp = 5 * (State.Energy * 0.5 + 0.5)
                        end

                        local SynthNoise = math.abs(math.sin(Phase)) * 0.4 + 0.6
                        local Noise2 = math.abs(math.sin(Phase * 2.3 + i * 1.7)) * 0.2 + 0.8
                        local Combined = SynthNoise * Noise2

                        local PitchHeight = 0
                        if PitchVal > 0 then
                            PitchHeight = PitchVal * 8 * LoudnessNorm
                        end

                        local BeatHeight = 0
                        if i <= 2 then
                            BeatHeight = BeatBoost
                        end

                        local SynthHeight = SynthAmp * Combined

                        local Height = SynthBase + SynthHeight + PitchHeight + BeatHeight
                        Height = MathClamp(Height, 2, 14)
                        Bar.Instance.Size = UDim2New(0, 4, 0, Height)
                    end
                else
                    State.LastFrameTime = 0
                end

