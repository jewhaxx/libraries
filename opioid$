        local SpotifyRequest = function(method, url, body)
            if not Library.SpotifyToken or Library.SpotifyToken == "" then
                LastError = "No token set"
                return nil, 0
            end

            if not HttpRequest then
                LastError = "No HTTP function found"
                return nil, 0
            end

            local Token = Library.SpotifyToken
            if Token:lower():sub(1, 7) == "bearer " then
                Token = Token:sub(8)
            end

            local RequestOptions = {
                Url = url,
                Method = method,
                Headers = {
                    ["Authorization"] = "Bearer " .. Token,
                    ["Content-Type"] = "application/json",
                    ["Accept"] = "application/json"
                }
            }

            if body and body ~= "" then
                RequestOptions.Body = body
            end

            local Success, Response = pcall(HttpRequest, RequestOptions)

            if not Success then
                LastError = tostring(Response):sub(1, 100)
                return nil, 0
            end

            if not Response then
                LastError = "Empty response"
                return nil, 0
            end

            local ResBody = Response.Body or Response.body or ""
            local ResCode = Response.StatusCode or Response.statusCode or Response.Status or 0

            if type(ResCode) == "string" then
                ResCode = tonumber(ResCode:match("(%d+)")) or 0
            end

            return ResBody, ResCode
        end

        local ShowDebug = false

        local UpdateFromSpotify = function()
            local Body, Code = SpotifyRequest("GET", "https://api.spotify.com/v1/me/player/currently-playing")

            if ShowDebug then
                ShowDebug = false
                if Code == 0 then
                    Library:Notification("Music: " .. LastError, 7, FromRGB(220, 90, 90))
                elseif Code == 401 then
                    Library:Notification("Music: Token invalid/expired (401)", 5, FromRGB(220, 90, 90))
                elseif Code == 204 then
                    Library:Notification("Music: Connected! No song playing (204)", 5, Library.Theme.Accent)
                elseif Code == 200 then
                    Library:Notification("Music: Connected & playing! (200)", 5, Library.Theme.Accent)
                else
                    Library:Notification("Music: HTTP " .. tostring(Code), 5, FromRGB(220, 90, 90))
                end
            end

            if Code == 204 or Code == 0 or not Body or Body == "" then
                State.IsPlaying = false
                Items["PlayBtn"].Instance.Text = "Play"
                Items["EqHolder"].Instance.Visible = false
                return
            end

            if Code ~= 200 then
                if Code == 401 then
                    Items["SongName"].Instance.Text = "Token expired"
                    Items["AlbumName"].Instance.Text = "Re-authenticate"
                    Items["ArtistName"].Instance.Text = "-"
                end
                return
            end

            local Success, Data = pcall(function()
                return HttpService:JSONDecode(Body)
            end)

            if not Success or not Data then
                return
