                local Descendants = SubItems["Content"].Instance:GetDescendants()
                TableInsert(Descendants, SubItems["Content"].Instance)

                if not Bool then
                    SubItems["Content"].Instance.Visible = false
                end
                task.delay(0.1, function()
                    Debounce = false
                end)
            end

