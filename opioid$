                if HasChildren then
                    InstanceTree.Expanded[Instance] = not (InstanceTree.Expanded[Instance] == true)
                    RebuildTree()
                end
            end)

            ApplySelectionVisual(Entry)
            TableInsert(RowEntries, Entry)

            if Expanded and HasChildren then
                table.sort(Children, function(A, B)
                    local AN = A.Name or "?"
                    local BN = B.Name or "?"
                    return AN:lower() < BN:lower()
                end)

                for _, Child in Children do
                    BuildRow(Child, Depth + 1)
                end
            end
        end

        RebuildTree = function()
            ClearTree()

            for _, Instance in InstanceTree.Roots do
                BuildRow(Instance, 0)
            end

            UpdateCanvasSize("TreeScroll")
        end

        local CollectRoots = function()
            local Roots = { }
            local Candidates = {
                game:GetService("Workspace"),
                LocalPlayer,
                game:GetService("ReplicatedStorage"),
                game:GetService("ReplicatedFirst"),
                game:GetService("StarterGui"),
                game:GetService("StarterPlayer"),
                game:GetService("StarterPack"),
                game:GetService("Lighting"),
                game:GetService("SoundService"),
                game:GetService("CoreGui")
            }

            for _, Instance in Candidates do
                if Instance then
                    TableInsert(Roots, Instance)
                end
            end

            table.sort(Roots, function(A, B)
                local AN = A.Name or "?"
                local BN = B.Name or "?"
                return AN:lower() < BN:lower()
            end)

            return Roots
        end

