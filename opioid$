                TextYAlignment = Enum.TextYAlignment.Center,
                BorderSizePixel = 0,
                TextSize = 11,
                TextTruncate = Enum.TextTruncate.AtEnd,
                BackgroundColor3 = FromRGB(255, 255, 255),
                Name = "\0"
            })
            Entry.Label:AddToTheme({ TextColor3 = "Text" })

            Instances:Create("UIStroke", {
                Parent = Entry.Label.Instance,
                LineJoinMode = Enum.LineJoinMode.Miter,
                Name = "\0"
            }):AddToTheme({ Color = "Text Border" })

            Entry.Button:OnHover(function()
                if InstanceTree.Selected ~= Instance then
                    Entry.Button.Instance.BackgroundTransparency = 0
                    Entry.Button.Instance.BackgroundColor3 = Library.Theme["Hovered Element"]
                end
            end)

            Entry.Button:OnHoverLeave(function()
                if InstanceTree.Selected ~= Instance then
                    Entry.Button.Instance.BackgroundTransparency = 1
                end
            end)

            Entry.Button:Connect("MouseButton1Down", function()
                InstanceTree.Selected = Instance
                BuildPropsFor(Instance)
                RebuildTree()
            end)

            Entry.Button:Connect("MouseButton2Down", function()
                InstanceTree.Selected = Instance
                BuildPropsFor(Instance)
                RebuildTree()
                OpenContextMenu(Instance)
            end)

