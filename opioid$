        local GetBoundingBox2D = function(model, cam, vpWidth, vpHeight, useViewport)
            local corners = {}
            for _, part in model:GetDescendants() do
                if part:IsA("BasePart") then
                    local s = part.Size / 2
                    local cf = part.CFrame
                    table.insert(corners, cf * Vector3.new(s.X, s.Y, s.Z))
                    table.insert(corners, cf * Vector3.new(-s.X, s.Y, s.Z))
                    table.insert(corners, cf * Vector3.new(s.X, -s.Y, s.Z))
                    table.insert(corners, cf * Vector3.new(-s.X, -s.Y, s.Z))
                    table.insert(corners, cf * Vector3.new(s.X, s.Y, -s.Z))
                    table.insert(corners, cf * Vector3.new(-s.X, s.Y, -s.Z))
                    table.insert(corners, cf * Vector3.new(s.X, -s.Y, -s.Z))
                    table.insert(corners, cf * Vector3.new(-s.X, -s.Y, -s.Z))
                end
            end
            if #corners == 0 then return nil end

            local minX, minY = math.huge, math.huge
            local maxX, maxY = -math.huge, -math.huge
            local anyInFront = false

            for _, c in corners do
                local rel = cam.CFrame:PointToObjectSpace(c)
                if rel.Z < -0.1 then
                    anyInFront = true
                    local sp
                    if useViewport then
                        sp = ProjectPointViewport(c, cam, vpWidth, vpHeight)
                    else
                        sp = ProjectPointScreen(c, cam)
                    end
                    if sp then
                        minX = math.min(minX, sp.X)
                        minY = math.min(minY, sp.Y)
                        maxX = math.max(maxX, sp.X)
                        maxY = math.max(maxY, sp.Y)
                    end
                end
            end

            if not anyInFront then return nil end
            if minX == math.huge then return nil end

            return { MinX = minX, MinY = minY, MaxX = maxX, MaxY = maxY }
        end



