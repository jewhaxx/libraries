                    end

                    if Item.id then
                        local FeatBody, FeatCode = SpotifyRequest("GET", "https://api.spotify.com/v1/audio-features/" .. Item.id)
                        if FeatCode == 200 and FeatBody then
                            local FSuccess, FeatData = pcall(function()
                                return HttpService:JSONDecode(FeatBody)
                            end)
                            if FSuccess and FeatData then
                                State.Tempo = FeatData.tempo or 120
                                State.Energy = FeatData.energy or 0.5
                                State.Danceability = FeatData.danceability or 0.5
