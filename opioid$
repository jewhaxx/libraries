                    SDIcon.Text = "+"
                end
                CurrentStatus = "Neutral"
                StatusDropdown.Text = "Neutral"
                return
            end

            local Success, Thumbnail = pcall(function()
                return Players:GetUserThumbnailAsync(Player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
            end)

            if Success and Thumbnail then
                AvatarFrame.Image = Thumbnail
            end

            DetailName.Text = Player.DisplayName .. " (@" .. Player.Name .. ")"
            DetailId.Text = "UserID: " .. tostring(Player.UserId)

            if Player == LocalPlayer then
                DetailStatus.Text = "Status: Local Player"
                DetailStatus.TextColor3 = StatusColors.Local
            else
                local PlayerData = Playerlist.Players[Player.Name]
                local Status = PlayerData and PlayerData.Status or "Neutral"
                DetailStatus.Text = "Status: " .. Status
                DetailStatus.TextColor3 = StatusColors[Status] or StatusColors.Neutral
            end

            CopyNameIcon.Visible = true
            CopyIdIcon.Visible = true
            UpdateCopyIconPositions()

            if SpectatingState.Active and SpectatingState.Player ~= Player then
                StopSpectating()
                SpectateToggleOn = false
                UpdateSpectateToggleVisual()
