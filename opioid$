        local FormatInstanceName = function(Instance)
            if not Instance then
                return "nil", "nil"
            end
            return Instance.Name or "?", Instance.ClassName or "?"
        end

        local GetInstanceValue = function(Instance)
            local Success, Value = pcall(function()
                return Instance.Value
            end)

            if not Success or Value == nil then
                return nil
            end

            if typeof(Value) == "Instance" then
                return Value.Name and (Value.Name .. " [" .. (Value.ClassName or "?") .. "]") or "nil"
            elseif typeof(Value) == "EnumItem" then
                return tostring(Value)
            elseif typeof(Value) == "Color3" then
                return StringFormat("R:%d G:%d B:%d", Value.R * 255, Value.G * 255, Value.B * 255)
            elseif typeof(Value) == "Vector3" then
                return StringFormat("%.2f, %.2f, %.2f", Value.X, Value.Y, Value.Z)
            elseif typeof(Value) == "CFrame" then
                return tostring(Value)
            elseif typeof(Value) == "BrickColor" then
                return tostring(Value)
            end

            return tostring(Value)
        end

        local GetInstancePath = function(Instance)
            if not Instance then
                return ""
            end

            local Segments = { }
            local Current = Instance

            while Current and Current ~= game do
                local Name = Current.Name or "?"
                if Name == "" then
                    Name = "?"
                end
                TableInsert(Segments, 1, Name)
                Current = Current.Parent
            end

            if #Segments == 0 then
                return "game"
            end

            return "game." .. TableConcat(Segments, ".")
        end

