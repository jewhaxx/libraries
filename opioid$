                    pcall(function() IsFolder = isfolder(File) end)
                    if IsFolder then
                        TableInsert(Folders, {Name = Name, FullPath = File})
                    elseif StringFind(Name:lower(), "%.json$") then
                        TableInsert(JsonFiles, {Name = Name, FullPath = File})
                    end
                end
            end

            table.sort(Folders, function(a, b) return a.Name:lower() < b.Name:lower() end)
            table.sort(JsonFiles, function(a, b) return a.Name:lower() < b.Name:lower() end)

