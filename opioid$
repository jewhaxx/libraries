        end

        Library:Connect(Players.PlayerAdded, function(player)
            if ESPPreview.Config.Enabled then
                task.wait(1)
                DrawPlayerESP(player)
            end
        end)

        Library:Connect(Players.PlayerRemoving, function(player)
            ClearPlayerOverlay(player)
        end)

        task.spawn(function()
            local AnimationCheckTimer = 0
            while true do
                -- Dummy preview ALWAYS draws when the ESPPreview window is visible.
                -- The dummy is the preview — it should show ESP drawings regardless of
                -- whether real-player ESP is enabled.
                pcall(DrawDummyESP)

                AnimationCheckTimer = AnimationCheckTimer + 0.03
                if AnimationCheckTimer >= 3 then
                    AnimationCheckTimer = 0
                    pcall(function()
                        if DummyParts and DummyParts.DanceTrack then
                            if not DummyParts.DanceTrack.IsPlaying then
                                DummyParts.DanceTrack:Play(0.1)
                            end
                        elseif DummyParts and DummyParts.ReloadAnimation then
                            DummyParts.ReloadAnimation()
                        end
                    end)
                end

                -- Real-player ESP only draws when Config.Enabled is true
                if ESPPreview.Config.Enabled then
                    for _, player in Players:GetPlayers() do
                        if player ~= LocalPlayer then
                            pcall(DrawPlayerESP, player)
                        end
                    end
                end
                task.wait(0.03)
            end
        end)

        task.spawn(function()
            while true do
                if not Dragging then
                    CamAngle = CamAngle + 0.005
                end
                if VpCamera and VpCamera.Parent then
                    UpdateCamera()
                end
                task.wait(0.016)
            end
        end)

        ESPPreview.Items = Items
        ESPPreview.StatusColors = StatusColors

        Library.ESPPreviewInstance = ESPPreview

        return ESPPreview
    end

