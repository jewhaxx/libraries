        function Window:SetOpen(Bool)
            if Window.IsOpen == Bool then
                return
            end

            Window.IsOpen = Bool

            local Frame = Items["MainFrame"].Instance
            Frame.Visible = Bool
        end

        Library:Connect(UserInputService.InputBegan, function(Input)
            local InputKey = tostring(Input.KeyCode)
            local InputType = tostring(Input.UserInputType)

            local MenuKey = Library.MenuKeybind
            local FlagData = Library.Flags["Settings_MenuKeybind"]
            if type(FlagData) == "table" and FlagData.Key then
                MenuKey = FlagData.Key
            end

            if InputKey == MenuKey or InputType == MenuKey then
                Window:SetOpen(not Window.IsOpen)
            end
        end)

        Window.Elements = Items

        return setmetatable(Window, Library)
    end

