                DummyBoxOutline.Visible = true
                DummyBoxColor.Color = Color
                DummyBoxColor.Thickness = 1
                DummyBoxOutlineStroke.Thickness = 3
                DummyCorners.Visible = false
            else
                DummyBoxHandler.Visible = false
                DummyBoxOutline.Visible = false
                DummyCorners.Visible = false
            end

            if ESPPreview.Config.ShowHealth then
                local humanoid = DummyHumanoid
                local ratio = 1
                if humanoid then
                    ratio = MathClamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
                end
                DummyHpFill.Size = UDim2New(1, -2, ratio, -2)
                DummyHpFill.Position = UDim2New(0, 1, 1 - ratio, 1)
                if ratio > 0.5 then
                    DummyHpFill.BackgroundColor3 = StatusColors.Friendly
                elseif ratio > 0.25 then
                    DummyHpFill.BackgroundColor3 = FromRGB(255, 200, 50)
                else
