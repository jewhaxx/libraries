            Instances:Create("UIStroke", {
                Parent = Entry.Arrow.Instance,
                LineJoinMode = Enum.LineJoinMode.Miter,
                Name = "\0"
            }):AddToTheme({ Color = "Text Border" })

            local DisplayClass = Class
            local Success, IsService = pcall(function() return Instance:IsA("Service") end)
            if Success and IsService then
                DisplayClass = "Service"
            end

            local DisplayText = StringFormat("%s [%s]", Name, DisplayClass)
            if #DisplayClass > 14 then
                DisplayText = StringFormat("%s [%s...]", Name, DisplayClass:sub(1, 11))
            end

            Entry.Label = Instances:Create("TextLabel", {
                Parent = Entry.Button.Instance,
                FontFace = Library.Font,
                TextColor3 = FromRGB(200, 200, 208),
                Text = DisplayText,
                BackgroundTransparency = 1,
                Position = UDim2New(0, Depth * 12 + 16, 0, 3),
