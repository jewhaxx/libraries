    Library.AddTooltip = function(self, Element, Text)
        if not Text or Text == "" then return end
        CreateGlobalTooltip()

        Element.MouseEnter:Connect(function()
            TooltipGen = TooltipGen + 1
            CancelTooltipTweens()

            TooltipActive = true
            TooltipLabel.Instance.Text = Text

            local MousePos = UserInputService:GetMouseLocation()
            local GuiInset = game:GetService("GuiService"):GetGuiInset().Y
            TooltipFrame.Instance.Position = UDim2New(0, MousePos.X + 12, 0, MousePos.Y - GuiInset + 12)

            TooltipFrame.Instance.BackgroundTransparency = 1
            TooltipLabel.Instance.TextTransparency = 1

            local FrameStroke = TooltipFrame.Instance:FindFirstChildOfClass("UIStroke")
            if FrameStroke then FrameStroke.Transparency = 1 end

            TooltipFrame.Instance.Visible = true

            local TweenInfoObj = TweenInfo.new(Library.Tween.Time, Library.Tween.Style, Library.Tween.Direction)

            local T1 = TweenService:Create(TooltipFrame.Instance, TweenInfoObj, { BackgroundTransparency = 0 })
            local T2 = TweenService:Create(TooltipLabel.Instance, TweenInfoObj, { TextTransparency = 0 })
            T1:Play()
            T2:Play()
            TooltipTweens = { T1, T2 }

            if FrameStroke then
                local T3 = TweenService:Create(FrameStroke, TweenInfoObj, { Transparency = 0 })
                T3:Play()
                TableInsert(TooltipTweens, T3)
            end

            if TooltipConnection then TooltipConnection:Disconnect() end
            TooltipConnection = UserInputService.InputChanged:Connect(function(Input)
                if Input.UserInputType == Enum.UserInputType.MouseMovement and TooltipActive then
                    local NewMousePos = UserInputService:GetMouseLocation()
                    TooltipFrame.Instance.Position = UDim2New(0, NewMousePos.X + 12, 0, NewMousePos.Y - GuiInset + 12)
                end
            end)
        end)

        Element.MouseLeave:Connect(function()
            TooltipGen = TooltipGen + 1
            local MyGen = TooltipGen

            -- MouseLeave fires when the cursor hops onto a CHILD of the element (Indicator, Text, etc.).
            -- Re-check the bounding box every frame so we only fade out when the cursor truly leaves.
            -- NOTE: Mouse.X/Y and AbsolutePosition are both in screen space (include the top inset bar),
            -- so we compare directly with NO inset adjustment. Subtracting GuiInset here (previous bug)
            -- shifted the cursor up ~36px and made IsOutside return true while still hovering the element.
            local function IsOutside()
                local P, S = Element.AbsolutePosition, Element.AbsoluteSize
                return not (Mouse.X >= P.X and Mouse.X <= P.X + S.X
                        and Mouse.Y >= P.Y and Mouse.Y <= P.Y + S.Y)
            end

            local function FadeOut()
                if TooltipGen ~= MyGen then return end
                if not IsOutside() then
                    -- Cursor is still over the element (or one of its children). Re-check next frame.
                    task.defer(FadeOut)
                    return
                end

                TooltipActive = false
                CancelTooltipTweens()

                if TooltipConnection then
                    TooltipConnection:Disconnect()
                    TooltipConnection = nil
                end

                local FrameStroke = TooltipFrame.Instance:FindFirstChildOfClass("UIStroke")
                local TweenInfoObj = TweenInfo.new(Library.Tween.Time, Library.Tween.Style, Library.Tween.Direction)

                local T1 = TweenService:Create(TooltipFrame.Instance, TweenInfoObj, { BackgroundTransparency = 1 })
                local T2 = TweenService:Create(TooltipLabel.Instance, TweenInfoObj, { TextTransparency = 1 })
                T1:Play()
                T2:Play()
                TooltipTweens = { T1, T2 }

                if FrameStroke then
                    local T3 = TweenService:Create(FrameStroke, TweenInfoObj, { Transparency = 1 })
                    T3:Play()
                    TableInsert(TooltipTweens, T3)
                end

                local CompletedConn
                CompletedConn = T1.Completed:Connect(function(PlaybackState)
                    -- Only hide on natural completion -- Cancel() also fires Completed and would briefly
                    -- yank Visible=false mid re-enter.
                    if PlaybackState == Enum.PlaybackState.Completed and not TooltipActive then
                        TooltipFrame.Instance.Visible = false
                    end
                    CompletedConn:Disconnect()
                end)
            end

            task.defer(FadeOut)
        end)
    end

