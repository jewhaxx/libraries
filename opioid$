        local PointHandles = { }
        local CurveDots = { }
        local DebugLabels = { }
        local DotsPerSegment = 20

        local GetMousePos = function()
            local MousePos = UserInputService:GetMouseLocation()
            local GuiInset = game:GetService("GuiService"):GetGuiInset().Y
            return Vector2New(MousePos.X, MousePos.Y - GuiInset)
        end

        local GetRelativePos = function()
            local MPos = GetMousePos()
            local CPos = CanvasInstance.AbsolutePosition
            local CSize = CanvasInstance.AbsoluteSize
            local RelX = MathClamp((MPos.X - CPos.X) / CSize.X, 0, 1)
            local RelY = MathClamp((MPos.Y - CPos.Y) / CSize.Y, 0, 1)
            return RelX, RelY, MPos
        end

        local FindNearestPoint = function(RelX, RelY)
            local NearestIndex = nil
            local NearestDist = 0.06

            for i, Pt in Bezier.Points do
                local DX = Pt[1] - RelX
                local DY = Pt[2] - (1 - RelY)
                local Dist = math.sqrt(DX * DX + DY * DY)
                if Dist < NearestDist then
                    NearestDist = Dist
                    NearestIndex = i
                end
            end

            return NearestIndex
        end

        local DrawCurve = function()
            local CWidth = CanvasInstance.AbsoluteSize.X
            local CHeight = CanvasInstance.AbsoluteSize.Y
            if CWidth <= 0 or CHeight <= 0 then
                return
            end

            local TotalDots = (#Bezier.Points - 1) * DotsPerSegment
            if TotalDots < 1 then
                TotalDots = 1
            end

            local DotIndex = 1
            local AllPoints = { }

            for i = 1, #Bezier.Points do
                AllPoints[i] = Bezier.Points[i]
            end

            if #AllPoints >= 2 then
                if #AllPoints == 2 then
                    AllPoints = { AllPoints[1], AllPoints[1], AllPoints[2], AllPoints[2] }
                elseif #AllPoints == 3 then
                    TableInsert(AllPoints, 1, AllPoints[1])
                    TableInsert(AllPoints, AllPoints[#AllPoints])
                else
                    TableInsert(AllPoints, 1, AllPoints[1])
                    TableInsert(AllPoints, AllPoints[#AllPoints])
                end

                for seg = 2, #AllPoints - 2 do
                    local P0 = AllPoints[seg - 1]
                    local P1 = AllPoints[seg]
                    local P2 = AllPoints[seg + 1]
                    local P3 = AllPoints[seg + 2]

                    for d = 0, DotsPerSegment - 1 do
                        local t = d / DotsPerSegment
                        local X, Y = CatmullRom(t, P0, P1, P2, P3)

                        local Dot = CurveDots[DotIndex]
                        if not Dot then
                            Dot = InstanceNew("Frame")
                            Dot.Name = "\0"
                            Dot.BackgroundColor3 = Library.Theme.Accent
                            Dot.BorderSizePixel = 0
                            Dot.Size = UDim2New(0, 2, 0, 2)
                            Dot.AnchorPoint = Vector2New(0.5, 0.5)
                            Dot.ZIndex = 3
                            Dot.Parent = CurveLayer

                            local Stroke = InstanceNew("UIStroke")
                            Stroke.Color = FromRGB(0, 0, 0)
                            Stroke.Transparency = 0.5
                            Stroke.Parent = Dot

                            CurveDots[DotIndex] = Dot
                        end

                        Dot.Position = UDim2New(X, 0, 1 - Y, 0)
                        Dot.BackgroundColor3 = Library.Theme.Accent
                        Dot.Visible = true
                        DotIndex = DotIndex + 1
                    end
                end

                local LastPt = Bezier.Points[#Bezier.Points]
                local Dot = CurveDots[DotIndex]
                if not Dot then
                    Dot = InstanceNew("Frame")
                    Dot.Name = "\0"
                    Dot.BackgroundColor3 = Library.Theme.Accent
                    Dot.BorderSizePixel = 0
                    Dot.Size = UDim2New(0, 2, 0, 2)
                    Dot.AnchorPoint = Vector2New(0.5, 0.5)
                    Dot.ZIndex = 3
                    Dot.Parent = CurveLayer
                    CurveDots[DotIndex] = Dot
                end
                Dot.Position = UDim2New(LastPt[1], 0, 1 - LastPt[2], 0)
                Dot.BackgroundColor3 = Library.Theme.Accent
                Dot.Visible = true
                DotIndex = DotIndex + 1
            end

            for i = DotIndex, #CurveDots do
                CurveDots[i].Visible = false
            end

            for i, Pt in Bezier.Points do
                local Handle = PointHandles[i]
                if not Handle then
                    Handle = InstanceNew("Frame")
                    Handle.Name = "\0"
                    Handle.BackgroundColor3 = Library.Theme.Accent
                    Handle.BorderColor3 = FromRGB(10, 10, 10)
                    Handle.BorderSizePixel = 2
                    Handle.Size = UDim2New(0, 7, 0, 7)
                    Handle.AnchorPoint = Vector2New(0.5, 0.5)
                    Handle.ZIndex = 4
                    Handle.Parent = HandleLayer

                    local Stroke = InstanceNew("UIStroke")
                    Stroke.Color = FromRGB(27, 27, 32)
                    Stroke.Parent = Handle

                    PointHandles[i] = Handle
                end

                Handle.Position = UDim2New(Pt[1], 0, 1 - Pt[2], 0)
                Handle.BackgroundColor3 = Library.Theme.Accent
                Handle.Visible = true
            end

            for i = #Bezier.Points + 1, #PointHandles do
                PointHandles[i].Visible = false
            end

            for i = #DebugLabels, 1, -1 do
                if i > #Bezier.Points then
                    DebugLabels[i]:Destroy()
                    DebugLabels[i] = nil
                end
            end

            for i, Pt in Bezier.Points do
                local Label = DebugLabels[i]
                if not Label then
                    Label = InstanceNew("TextLabel")
                    Label.Name = "\0"
                    Label.FontFace = Library.Font
                    Label.TextColor3 = FromRGB(150, 150, 158)
                    Label.BackgroundTransparency = 1
                    Label.Size = UDim2New(1, 0, 0, 11)
                    Label.BorderSizePixel = 0
                    Label.TextSize = 10
                    Label.TextXAlignment = Enum.TextXAlignment.Left
                    Label.TextYAlignment = Enum.TextYAlignment.Center
                    Label.BackgroundColor3 = FromRGB(255, 255, 255)
                    Label.Parent = DebugHolder

                    local Stroke = InstanceNew("UIStroke")
                    Stroke.Color = FromRGB(0, 0, 0)
                    Stroke.Parent = Label

                    DebugLabels[i] = Label
                end

                Label.Text = StringFormat("Point%d: %.3f, %.3f", i, Pt[1], Pt[2])
            end
        end

        local FireCallback = function()
            local ReturnPoints = { }
            for _, Pt in Bezier.Points do
                TableInsert(ReturnPoints, { Pt[1], Pt[2] })
            end
            Library.Flags[Bezier.Flag] = ReturnPoints
            Library:SafeCall(Bezier.Callback, ReturnPoints)
        end

        CanvasInstance.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton2 or Input.UserInputType == Enum.UserInputType.Touch then
                local RelX, RelY = GetRelativePos()
                local NearestIdx = FindNearestPoint(RelX, RelY)

                if NearestIdx and #Bezier.Points > 2 then
                    TableRemove(Bezier.Points, NearestIdx)
                    DrawCurve()
                    FireCallback()
                else
                    TableInsert(Bezier.Points, { RelX, 1 - RelY })
                    table.sort(Bezier.Points, function(A, B)
                        return A[1] < B[1]
                    end)
                    DrawCurve()
                    FireCallback()
                end
            elseif Input.UserInputType == Enum.UserInputType.MouseButton1 then
                local RelX, RelY = GetRelativePos()
                local NearestIdx = FindNearestPoint(RelX, RelY)

                if NearestIdx then
                    Bezier.SlidingPoint = NearestIdx
                else
                    Bezier.DraggingWindow = true
                    local MainFrame = Bezier.Window.Elements["MainFrame"].Instance
                    Bezier._DragStart = Input.Position
                    Bezier._DragStartPos = MainFrame.Position
                end
            end
        end)

        CanvasInstance.InputEnded:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                Bezier.SlidingPoint = nil
                Bezier.DraggingWindow = false
            end
        end)

        Library:Connect(UserInputService.InputChanged, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
                if Bezier.SlidingPoint then
                    local RelX, RelY = GetRelativePos()
                    Bezier.Points[Bezier.SlidingPoint] = { RelX, 1 - RelY }
                    table.sort(Bezier.Points, function(A, B)
                        return A[1] < B[1]
                    end)

                    for i, Pt in Bezier.Points do
                        if Pt[1] == RelX and Pt[2] == (1 - RelY) then
                            Bezier.SlidingPoint = i
                            break
                        end
                    end

                    DrawCurve()
                    FireCallback()
                elseif Bezier.DraggingWindow then
                    local MainFrame = Bezier.Window.Elements["MainFrame"].Instance
                    local DragDelta = Input.Position - Bezier._DragStart
                    local NewX = Bezier._DragStartPos.X.Offset + DragDelta.X
                    local NewY = Bezier._DragStartPos.Y.Offset + DragDelta.Y
                    local ViewportX = Camera.ViewportSize.X
                    local ViewportY = Camera.ViewportSize.Y
                    local FrameW = MainFrame.AbsoluteSize.X
                    local FrameH = MainFrame.AbsoluteSize.Y
                    NewX = MathClamp(NewX, 0, ViewportX - FrameW)
                    NewY = MathClamp(NewY, 0, ViewportY - FrameH)
                    MainFrame.Position = UDim2New(0, NewX, 0, NewY)
                end
            end
        end)

        Library:Connect(CanvasInstance:GetPropertyChangedSignal("AbsoluteSize"), function()
            task.wait()
            DrawCurve()
        end)

        Library:Connect(CanvasInstance:GetPropertyChangedSignal("AbsolutePosition"), function()
            task.wait()
            DrawCurve()
        end)

        function Bezier:Set(Points)
            if type(Points) ~= "table" then
                return
            end

            Bezier.Points = { }
            for _, Pt in Points do
                TableInsert(Bezier.Points, {
                    MathClamp(Pt[1] or 0, 0, 1),
                    MathClamp(Pt[2] or 0, 0, 1)
                })
            end

            if #Bezier.Points < 2 then
                Bezier.Points = { { 0, 0 }, { 1, 1 } }
            end

            table.sort(Bezier.Points, function(A, B)
                return A[1] < B[1]
            end)

            DrawCurve()
            FireCallback()
        end

        function Bezier:Get()
            local ReturnPoints = { }
            for _, Pt in Bezier.Points do
                TableInsert(ReturnPoints, { Pt[1], Pt[2] })
            end
            return ReturnPoints
        end

        function Bezier:Evaluate(t)
            t = MathClamp(t, 0, 1)
            if #Bezier.Points < 2 then
                return 0
            end

            if #Bezier.Points == 2 then
                local P1 = Bezier.Points[1]
                local P2 = Bezier.Points[2]
                return P1[2] + (P2[2] - P1[2]) * t
            end

            local AllPoints = { }
            for _, Pt in Bezier.Points do
                TableInsert(AllPoints, Pt)
            end
            TableInsert(AllPoints, 1, AllPoints[1])
            TableInsert(AllPoints, AllPoints[#AllPoints])

            local TotalSegs = #AllPoints - 3
            local SegT = t * TotalSegs
            local SegIndex = MathFloor(SegT) + 1
            if SegIndex >= TotalSegs then
                SegIndex = TotalSegs
                SegT = 1
            else
                SegT = SegT - (SegIndex - 1)
            end

            local P0 = AllPoints[SegIndex]
            local P1 = AllPoints[SegIndex + 1]
            local P2 = AllPoints[SegIndex + 2]
            local P3 = AllPoints[SegIndex + 3]

            local _, Y = CatmullRom(SegT, P0, P1, P2, P3)
            return Y
        end

        function Bezier:SetVisibility(Bool)
            Items["Bezier"].Instance.Visible = Bool
        end

        function Bezier:AddPoint(X, Y)
            TableInsert(Bezier.Points, { MathClamp(X, 0, 1), MathClamp(Y, 0, 1) })
            table.sort(Bezier.Points, function(A, B)
                return A[1] < B[1]
            end)
            DrawCurve()
            FireCallback()
        end

        function Bezier:RemovePoint(Index)
            if #Bezier.Points <= 2 then
                return
            end
            TableRemove(Bezier.Points, Index)
            DrawCurve()
            FireCallback()
        end

        Library.Flags[Bezier.Flag] = { }
        for _, Pt in Bezier.Points do
            TableInsert(Library.Flags[Bezier.Flag], { Pt[1], Pt[2] })
        end

        Library.SetFlags[Bezier.Flag] = function(Value)
            Bezier:Set(Value)
        end

        task.defer(function()
            task.wait(0.1)
            DrawCurve()
        end)

        return Bezier
    end
