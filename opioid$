                Count = Toggle.Count,

                FadeSpeed = self.Window.FadeSpeed
            }

            Toggle.Count += 1
            Colorpicker.Count = Toggle.Count

            local Extension = Library:CreateColorpicker(Colorpicker)
            Library.Flags[Colorpicker.Flag] = Extension

            if Extension.Items and Extension.Items["ColorpickerButton"] then
                Extension.Items["ColorpickerButton"].Instance.Parent = Items["RightContainer"].Instance
                Extension.Items["ColorpickerButton"].Instance.AnchorPoint = Vector2New(0, 0.5)
                Extension.Items["ColorpickerButton"].Instance.Position = UDim2New(0, 0, 0.5, 0)
